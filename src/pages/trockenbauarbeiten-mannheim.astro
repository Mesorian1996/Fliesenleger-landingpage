---
import Base from '@/layouts/Base.astro';
import Icon from '@/components/ui/Icon.astro';
import Navbar from '@/components/global/Navbar.astro';
import Footer from '@/components/global/Footer.astro';
import HeroSubpage from '@/components/sections/HeroSubpage.astro';
import ContactSection from '@/components/sections/ContactSection.astro';
import FaqSection from '@/components/sections/FaqSection.astro';

const faqs = [
  {
    q: 'Wozu brauche ich Trockenbau bei einer Badsanierung?',
    a: 'Trockenbau ermöglicht ebenerdige Duschen (Bodenaufbau), Vorwandinstallationen für Sanitär, Nischen und Aussparungen. Außerdem lassen sich damit schnell Wände versetzen oder neue Raumaufteilungen schaffen.',
  },
  {
    q: 'Wie wasserfest ist Trockenbau im Bad?',
    a: 'Wir verwenden ausschließlich feuchtigkeitsresistente Gipskartonplatten (Grüne Platten) und Aquapaneel im Nassbereich. Mit fachgerechter Flächenabdichtung nach DIN 18534 ist das System dauerhaft wassersicher.',
  },
  {
    q: 'Können Sie Trockenbau auch für Schallschutz oder Brandschutz ausführen?',
    a: 'Ja – Schallschutzwände (z.B. zwischen Wohneinheiten) und Brandschutztrennwände (F30/F90) gehören zu unserem Leistungsspektrum. Wir planen gemeinsam mit Ihnen die passende Lösung.',
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Trockenbauarbeiten Mannheim",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Limani Fliesenleger & Malerbetrieb",
    "url": "https://www.limani-fliesenleger.de"
  },
  "areaServed": "Mannheim",
  "description": "Trockenbauarbeiten in Mannheim – Wände, Decken, Vorwandinstallationen, ebenerdige Duschkonstruktionen. Präzise, schnell, dauerhaft."
};
---

<Base
  title="Trockenbauarbeiten Mannheim – Wände, Bad & Decken"
  description="Trockenbauarbeiten in Mannheim. Wände versetzen, Vorwandinstallationen, ebenerdige Duschen, Schallschutz. Saubere Ausführung, schnelle Termine. Jetzt anfragen."
  schema={schema}
>
  <Navbar />
  <main>
    <HeroSubpage
      label="Trockenbau"
      headline="Trockenbauarbeiten Mannheim – präzise & schnell"
      subline="Wände versetzen, Vorwandinstallationen, ebenerdige Duschkonstruktionen, abgehängte Decken. Wir setzen Ihre Trockenbauarbeiten in Mannheim termingerecht um."
      image="/assets/images/Fliesen_bad_12.jpeg"
      imageAlt="Trockenbauarbeiten Mannheim – Limani"
      ctaLabel="Kostenlos anfragen"
      ctaHref="#anfrage-funnel"
      breadcrumb={[{ label: 'Trockenbauarbeiten Mannheim' }]}
    />

    <section class="py-20 bg-white" aria-labelledby="trockenbauHeading">
      <div class="container">
        <span class="section-label">Leistungen</span>
        <h2 id="trockenbauHeading" style="font-size:clamp(1.625rem,2.5vw,2rem); margin:0.5rem 0 1.5rem; letter-spacing:-0.02em; max-width:600px;">
          Trockenbau für Bad, Wohnraum & Gewerbe
        </h2>
        <div class="tb-grid" data-aos="fade-up">
          {[
            { title: 'Trennwände', desc: 'Neue Raumaufteilungen, schnell und ohne Dreck – auch in bewohnten Wohnungen.' },
            { title: 'Vorwandinstallationen', desc: 'Für WC, Waschtisch, Dusche – unsichtbare Leitungsführung mit präzisem Abschluss.' },
            { title: 'Ebenerdige Dusche', desc: 'Bodenaufbau für gefälliges Gefälle, Abdichtung, Duschrinne – Vorbereitung für Fliesenleger.' },
            { title: 'Abgehängte Decken', desc: 'Deckenabhängungen für Leitungen, Akustik oder optische Gestaltung.' },
            { title: 'Nischen & Aussparungen', desc: 'Duschnisc hen, Regalnischen, Lichtnischen – exakt gemessen, sauber gebaut.' },
            { title: 'Schallschutzwände', desc: 'Zwischen Wohneinheiten oder Räumen – erhöhter Schallschutz nach Norm.' },
          ].map(s => (
            <article class="tb-card">
              <div class="tb-icon">
                <Icon name="drywall" size={20} strokeWidth={2} />
              </div>
              <h3 style="font-size:1rem; font-weight:600; margin:0 0 0.375rem; color:var(--color-text-heading);">{s.title}</h3>
              <p style="font-size:0.875rem; color:var(--color-text-muted); margin:0; line-height:1.6;">{s.desc}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <ContactSection heading="Trockenbau anfragen" subheading="Kurze Beschreibung des Projekts genügt – wir melden uns für einen Vor-Ort-Termin." showMap={false} />
    <FaqSection faqs={faqs} />
  </main>
  <Footer />
</Base>

<style>
  .tb-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px) { .tb-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .tb-grid { grid-template-columns: repeat(3, 1fr); } }

  .tb-card {
    background: var(--color-surface-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 1.5rem;
  }

  .tb-icon {
    width: 42px;
    height: 42px;
    border-radius: 0.75rem;
    background: rgba(232, 146, 42, 0.12);
    color: var(--color-brand-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0.875rem;
  }

  .py-20 { padding-top: 5rem; padding-bottom: 5rem; }
</style>
