---
import { SITE } from '@/config/site';
---

<footer class="footer-dark" aria-label="Seitenfu&szlig;">
  <div class="container">
    <div style="display:grid; grid-template-columns:1fr; gap:2.5rem;" class="footer-grid">

      <!-- Brand Column -->
      <div>
        <a href="/" aria-label="Limani Fliesenleger — Startseite" style="display:inline-block; margin-bottom:1rem;">
          <img
            src="/assets/images/Limani_Logo_modern.webp"
            alt="Limani Fliesenleger Logo"
            width="140"
            height="65"
            style="max-height:54px; width:auto; filter: brightness(0) invert(1); opacity:0.9;"
            loading="lazy"
          />
        </a>
        <p style="font-size:0.875rem; line-height:1.7; color:rgba(255,255,255,0.6); max-width:280px; margin:0 0 1rem;">
          Ihr Handwerksbetrieb in Mannheim für Fliesen, Bäder und komplette Wohnungssanierungen.
          Sauber, schnell und zuverlässig seit über 30 Jahren.
        </p>
        <div style="display:flex; gap:0.75rem;">
          <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="footer-social-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="footer-social-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href={SITE.social.google} target="_blank" rel="noopener noreferrer" aria-label="Google Bewertungen" class="footer-social-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.5 14.5H13v-4h-2v4H7.5V7.5H11v3h2v-3h3.5V16.5z" opacity="0.5"/>
              <path d="M12 7c-2.761 0-5 2.239-5 5s2.239 5 5 5c1.955 0 3.65-1.121 4.5-2.76H12V12h5.8c.13.61.2 1.247.2 1.9C18 17.313 15.313 20 12 20s-6-2.687-6-6 2.687-6 6-6c1.58 0 3.01.62 4.08 1.62l-1.68 1.68C13.74 10.55 12.92 10.2 12 10.2c-1.54 0-2.8 1.26-2.8 2.8s1.26 2.8 2.8 2.8c1.35 0 2.44-.95 2.72-2.22H12V12h5.8z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Leistungen -->
      <div>
        <h3 style="font-size:0.875rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.5); margin:0 0 1rem;">
          Leistungen
        </h3>
        <nav aria-label="Leistungen">
          <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.5rem;">
            {[
              ['Fliesenarbeiten', '/fliesenarbeiten-mannheim'],
              ['Badsanierung', '/badsanierung-mannheim'],
              ['Verputz & Malerarbeiten', '/malerarbeiten-mannheim'],
              ['Trockenbauarbeiten', '/trockenbauarbeiten-mannheim'],
              ['Bodenverlegung & Estrich', '/bodenarbeiten-mannheim'],
              ['Abbruch & Entsorgung', '/abbrucharbeiten-mannheim'],
              ['Wohnungssanierung', '/wohnungssanierung-mannheim'],
            ].map(([label, href]) => (
              <li>
                <a href={href} class="footer-link" style="font-size:0.9rem;">{label}</a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Kontakt -->
      <div>
        <h3 style="font-size:0.875rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:rgba(255,255,255,0.5); margin:0 0 1rem;">
          Kontakt
        </h3>
        <div style="display:flex; flex-direction:column; gap:0.75rem;">
          <a href={`tel:${SITE.phoneTel}`} class="footer-contact-row" aria-label="Anrufen">
            <span class="footer-contact-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.7H6.6a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.3a16 16 0 0 0 6 6l.86-1.22a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.4 17.4z"/>
              </svg>
            </span>
            <span class="footer-link">{SITE.phone}</span>
          </a>
          <a href={`mailto:${SITE.email}`} class="footer-contact-row" aria-label="E-Mail">
            <span class="footer-contact-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="20" height="16" rx="2"/>
                <polyline points="2,4 12,13 22,4"/>
              </svg>
            </span>
            <span class="footer-link">{SITE.email}</span>
          </a>
          <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="footer-contact-row" aria-label="WhatsApp">
            <span class="footer-contact-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
              </svg>
            </span>
            <span class="footer-link" style="color:rgba(134,239,172,0.9);">WhatsApp schreiben</span>
          </a>
          <div class="footer-contact-row" style="cursor:default;">
            <span class="footer-contact-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </span>
            <span style="font-size:0.9rem; color:rgba(255,255,255,0.65);">E7 13, 68159 Mannheim</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div style="margin-top:3rem; padding-top:1.5rem; border-top:1px solid rgba(255,255,255,0.1); display:flex; flex-wrap:wrap; justify-content:space-between; align-items:center; gap:0.75rem;">
      <p style="font-size:0.8125rem; color:rgba(255,255,255,0.4); margin:0;">
        &copy; <span id="footerYear"></span> Limani Fliesenleger &amp; Malerbetrieb. Alle Rechte vorbehalten.
      </p>
      <nav aria-label="Rechtliches" style="display:flex; gap:1.25rem;">
        <a href="/impressum" class="footer-link" style="font-size:0.8125rem;">Impressum</a>
        <a href="/datenschutz" class="footer-link" style="font-size:0.8125rem;">Datenschutz</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer-grid {
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr;
    }
  }

  .footer-social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.7);
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }
  .footer-social-btn:hover {
    background: var(--color-brand-accent);
    color: #fff;
    transform: translateY(-2px);
  }

  .footer-contact-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .footer-contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 0.375rem;
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.6);
    flex-shrink: 0;
  }
</style>

<script>
  const yearEl = document.getElementById('footerYear');
  if (yearEl) yearEl.textContent = String(new Date().getFullYear());
</script>
