---
import { SITE } from '@/config/site';
import Icon from '@/components/ui/Icon.astro';
---

<footer class="footer-dark footer-compact" aria-label="Seitenfu&szlig;">
  <div class="container">
    <div class="footer-grid">

      <!-- Brand Column -->
      <div>
        <a href="/" aria-label="Limani Fliesenleger — Startseite" style="display:inline-block; margin-bottom:0.875rem;">
          <img
            src="/assets/images/Limani_Logo_modern.webp"
            alt="Limani Fliesenleger Logo"
            width="120"
            height="56"
            style="max-height:44px; width:auto; filter: brightness(0) invert(1); opacity:0.85;"
            loading="lazy"
          />
        </a>
        <p style="font-size:0.8125rem; line-height:1.65; color:rgba(255,255,255,0.55); max-width:240px; margin:0 0 0.875rem;">
          Fliesen, Bäder &amp; Wohnungssanierung in Mannheim – sauber, termintreu, Inhaber mit 30+ Jahren Erfahrung.
        </p>
        <div style="display:flex; gap:0.5rem;">
          <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="footer-social-btn">
            <Icon name="instagram" size={16} strokeWidth={1.8} />
          </a>
          <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="footer-social-btn">
            <Icon name="facebook" size={16} fill="currentColor" stroke="none" strokeWidth={0} />
          </a>
          <a href={SITE.social.google} target="_blank" rel="noopener noreferrer" aria-label="Google Bewertungen" class="footer-social-btn">
            <Icon name="google" size={16} fill="currentColor" stroke="none" strokeWidth={0} />
          </a>
        </div>
      </div>

      <!-- Leistungen -->
      <div>
        <h3 class="footer-col-heading">Leistungen</h3>
        <nav aria-label="Leistungen">
          <ul style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.375rem;">
            {[
              ['Fliesenarbeiten', '/fliesenarbeiten-mannheim'],
              ['Badsanierung', '/badsanierung-mannheim'],
              ['Verputz & Malerarbeiten', '/malerarbeiten-mannheim'],
              ['Trockenbauarbeiten', '/trockenbauarbeiten-mannheim'],
              ['Bodenverlegung & Estrich', '/bodenarbeiten-mannheim'],
              ['Abbruch & Entsorgung', '/abbrucharbeiten-mannheim'],
              ['Wohnungssanierung', '/wohnungssanierung-mannheim'],
            ].map(([label, href]) => (
              <li>
                <a href={href} class="footer-link footer-link-sm">{label}</a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Kontakt -->
      <div>
        <h3 class="footer-col-heading">Kontakt</h3>
        <div style="display:flex; flex-direction:column; gap:0.5rem;">
          <a href={`tel:${SITE.phoneTel}`} class="footer-contact-row" aria-label="Anrufen">
            <span class="footer-contact-icon">
              <img src="/assets/icons/phone-call.svg" width="14" height="14" alt="" loading="lazy" class="footer-icon-img" />
            </span>
            <span class="footer-link footer-link-sm">{SITE.phone}</span>
          </a>
          <a href={`mailto:${SITE.email}`} class="footer-contact-row" aria-label="E-Mail">
            <span class="footer-contact-icon">
              <img src="/assets/icons/email.svg" width="14" height="14" alt="" loading="lazy" class="footer-icon-img" />
            </span>
            <span class="footer-link footer-link-sm">{SITE.email}</span>
          </a>
          <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="footer-contact-row" aria-label="WhatsApp">
            <span class="footer-contact-icon">
              <Icon name="whatsapp" size={14} fill="currentColor" stroke="none" strokeWidth={0} />
            </span>
            <span class="footer-link footer-link-sm" style="color:rgba(134,239,172,0.85);">WhatsApp</span>
          </a>
          <div class="footer-contact-row" style="cursor:default;">
            <span class="footer-contact-icon">
              <Icon name="mapPin" size={14} strokeWidth={2} />
            </span>
            <span style="font-size:0.8125rem; color:rgba(255,255,255,0.55);">E7 13, 68159 Mannheim</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p style="font-size:0.75rem; color:rgba(255,255,255,0.35); margin:0;">
        &copy; <span id="footerYear"></span> Limani Fliesenleger &amp; Malerbetrieb
      </p>
      <nav aria-label="Rechtliches" style="display:flex; gap:1rem; align-items:center;">
        <a href="/impressum" class="footer-link" style="font-size:0.75rem;">Impressum</a>
        <a href="/datenschutz" class="footer-link" style="font-size:0.75rem;">Datenschutz</a>
      </nav>
      <p style="font-size:0.75rem; color:rgba(255,255,255,0.25); margin:0;">
        Made with <span style="color:rgba(232,146,42,0.7);">♥</span> by
        <a href="https://mydigitalworks.de" target="_blank" rel="noopener noreferrer" style="color:rgba(255,255,255,0.35); text-decoration:none; transition:color 0.2s;" onmouseover="this.style.color='rgba(255,255,255,0.6)'" onmouseout="this.style.color='rgba(255,255,255,0.35)'">mydigitalworks.de</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-compact {
    padding: 2.5rem 0 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 860px;
  }
  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem 2.5rem;
    }
  }
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 2rem 4rem;
    }
  }

  .footer-col-heading {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.45);
    margin: 0 0 0.75rem;
    font-family: var(--font-body);
  }

  .footer-link-sm {
    font-size: 0.8125rem !important;
  }

  .footer-social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.6);
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }
  .footer-social-btn:hover {
    background: var(--color-brand-accent);
    color: #fff;
    transform: translateY(-2px);
  }

  .footer-contact-row {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
  }

  .footer-contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 0.3rem;
    background: rgba(255,255,255,0.07);
    color: rgba(255,255,255,0.5);
    flex-shrink: 0;
  }

  .footer-icon-img {
    filter: brightness(0) invert(1);
    opacity: 0.5;
  }

  .footer-bottom {
    margin-top: 2rem;
    padding: 1rem 0;
    border-top: 1px solid rgba(255,255,255,0.08);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem 1rem;
  }
</style>

<script>
  const yearEl = document.getElementById('footerYear');
  if (yearEl) yearEl.textContent = String(new Date().getFullYear());
</script>
