---
/**
 * ContactSection
 * @category sections
 * @description Standalone contact form section wired to Cloudflare Worker / Resend.
 */

import { SITE } from '@/config/site';

interface Props {
  heading?: string;
  subheading?: string;
  showMap?: boolean;
}

const {
  heading = 'Kontakt aufnehmen',
  subheading = 'Schreiben Sie uns – oder rufen Sie direkt an. Wir melden uns innerhalb von 24 Stunden.',
  showMap = true,
} = Astro.props;
---

<section id="kontakt-form" class="py-20 bg-subtle" aria-labelledby="contactHeading">
  <div class="container">

    <div class="contact-layout">

      <!-- Left: Info + map -->
      <div class="contact-info" data-aos="fade-right">
        <span class="section-label">Direkt anfragen</span>
        <h2 id="contactHeading" style="font-size:clamp(1.75rem,3vw,2.5rem); margin:0 0 1rem; letter-spacing:-0.025em;">
          {heading}
        </h2>
        <p style="color:var(--color-text-muted); font-size:1rem; line-height:1.7; margin:0 0 2rem;">
          {subheading}
        </p>

        <div class="contact-rows">
          <a href={`tel:${SITE.phoneTel}`} class="contact-row">
            <div class="contact-row__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.7H6.6a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.3a16 16 0 0 0 6 6l.86-1.22a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.4 17.4z"/>
              </svg>
            </div>
            <div>
              <span class="contact-row__label">Telefon</span>
              <span class="contact-row__value">{SITE.phone}</span>
            </div>
          </a>

          <a href={`mailto:${SITE.email}`} class="contact-row">
            <div class="contact-row__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div>
              <span class="contact-row__label">E-Mail</span>
              <span class="contact-row__value">{SITE.email}</span>
            </div>
          </a>

          <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="contact-row">
            <div class="contact-row__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
              </svg>
            </div>
            <div>
              <span class="contact-row__label">WhatsApp</span>
              <span class="contact-row__value">Nachricht senden</span>
            </div>
          </a>

          <div class="contact-row" style="cursor:default;">
            <div class="contact-row__icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <span class="contact-row__label">Adresse</span>
              <span class="contact-row__value">{SITE.address.street}, {SITE.address.zip} {SITE.address.city}</span>
            </div>
          </div>
        </div>

        {showMap && (
          <div class="contact-map" data-aos="fade-up">
            <iframe
              title="Standort Limani Fliesenleger Mannheim"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2597.3!2d8.466!3d49.489!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4797cc1b4c4c4c4d%3A0x0!2sE7+13%2C+68159+Mannheim!5e0!3m2!1sde!2sde!4v1"
              width="100%"
              height="200"
              style="border:0; border-radius:var(--radius-card);"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        )}
      </div>

      <!-- Right: Form -->
      <div class="contact-form-wrap" data-aos="fade-left">
        <form id="contactForm" class="contact-form" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="cf-vorname">Vorname *</label>
              <input type="text" id="cf-vorname" name="vorname" required autocomplete="given-name" placeholder="Max" enterkeyhint="next" />
            </div>
            <div class="form-group">
              <label for="cf-nachname">Nachname *</label>
              <input type="text" id="cf-nachname" name="nachname" required autocomplete="family-name" placeholder="Mustermann" enterkeyhint="next" />
            </div>
          </div>

          <div class="form-group">
            <label for="cf-telefon">Telefon *</label>
            <input type="tel" id="cf-telefon" name="telefon" required autocomplete="tel" placeholder="0171 234 5678" enterkeyhint="next" />
          </div>

          <div class="form-group">
            <label for="cf-email">E-Mail *</label>
            <input type="email" id="cf-email" name="email" required autocomplete="email" placeholder="max@example.de" enterkeyhint="next" />
          </div>

          <div class="form-group">
            <label for="cf-nachricht">Ihre Nachricht</label>
            <textarea id="cf-nachricht" name="nachricht" rows="4" placeholder="Beschreiben Sie kurz Ihr Projekt – Fläche, Wunschtermin, besondere Anforderungen…" enterkeyhint="send"></textarea>
          </div>

          <!-- Honeypot -->
          <input type="text" name="_gotcha" style="display:none;" tabindex="-1" autocomplete="off" />

          <button type="submit" id="cfSubmitBtn" class="btn-primary" style="width:100%;">
            Nachricht absenden
          </button>

          <p id="cfSuccess" class="form-feedback form-feedback--success" hidden>
            Ihre Nachricht wurde gesendet. Wir melden uns innerhalb von 24 Stunden.
          </p>
          <p id="cfError" class="form-feedback form-feedback--error" hidden>
            Ein Fehler ist aufgetreten. Bitte rufen Sie uns direkt an: <a href="tel:+491733293668">0173 329 3668</a>
          </p>

          <p style="font-size:0.8125rem; color:var(--color-text-muted); margin:0.75rem 0 0; line-height:1.6;">
            * Pflichtfelder. Ihre Daten werden ausschließlich zur Bearbeitung Ihrer Anfrage verwendet.
          </p>
        </form>
      </div>

    </div>
  </div>
</section>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.5rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .contact-layout { grid-template-columns: 1fr 1fr; gap: 5rem; }
  }

  .contact-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    overflow: hidden;
    background: #fff;
    margin-bottom: 1.5rem;
  }

  .contact-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .contact-row:last-child { border-bottom: none; }
  a.contact-row:hover { background: var(--color-surface-subtle); }

  .contact-row__icon {
    width: 38px;
    height: 38px;
    border-radius: 0.625rem;
    background: rgba(232, 146, 42, 0.1);
    color: var(--color-brand-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-row__label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0.125rem;
  }

  .contact-row__value {
    display: block;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-heading);
  }

  .contact-map {
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  /* Form */
  .contact-form-wrap {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 2rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-group label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-heading);
  }

  .form-feedback {
    padding: 0.875rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }
  .form-feedback--success {
    background: rgba(34, 197, 94, 0.1);
    color: #15803d;
    border: 1px solid rgba(34, 197, 94, 0.25);
  }
  .form-feedback--error {
    background: rgba(239, 68, 68, 0.1);
    color: #b91c1c;
    border: 1px solid rgba(239, 68, 68, 0.25);
  }
  .form-feedback--error a { color: inherit; font-weight: 600; }

  .py-20 { padding-top: 5rem; padding-bottom: 5rem; }
</style>

<script>
  import { SITE } from '@/config/site';

  function initContactForm() {
    const form = document.getElementById('contactForm') as HTMLFormElement | null;
    if (!form) return;

    const submitBtn = document.getElementById('cfSubmitBtn') as HTMLButtonElement | null;
    const successMsg = document.getElementById('cfSuccess') as HTMLElement | null;
    const errorMsg = document.getElementById('cfError') as HTMLElement | null;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!submitBtn) return;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Wird gesendet…';

      successMsg?.setAttribute('hidden', '');
      errorMsg?.setAttribute('hidden', '');

      const formData = new FormData(form);
      const data: Record<string, string> = {};
      formData.forEach((value, key) => {
        if (key !== '_gotcha') data[key] = String(value);
      });

      // Honeypot check
      if (formData.get('_gotcha')) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Nachricht absenden';
        return;
      }

      try {
        const res = await fetch(SITE.workerUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          successMsg?.removeAttribute('hidden');
          form.reset();
          submitBtn.textContent = 'Gesendet';
        } else {
          throw new Error('Server error');
        }
      } catch {
        errorMsg?.removeAttribute('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Erneut senden';
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactForm);
  } else {
    initContactForm();
  }
</script>
