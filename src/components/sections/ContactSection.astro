---
/**
 * ContactSection
 * @category sections
 * @description Dark-themed contact section — form + info on navy background for high visibility.
 */

import { SITE } from '@/config/site';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  heading?: string;
  subheading?: string;
  showMap?: boolean;
}

const {
  heading = 'Jetzt kostenlos anfragen',
  subheading = 'Rufen Sie uns an oder nutzen Sie das Formular. Wir melden uns innerhalb von 24 Stunden mit einem unverbindlichen Angebot.',
  showMap = true,
} = Astro.props;
---

<section id="kontakt-form" class="contact-section" aria-labelledby="contactHeading">
  <div class="container">
    <div class="contact-layout">

      <!-- Left: Info -->
      <div class="contact-info" data-aos="fade-right">

        <span class="section-label section-label--accent">Direkt anfragen</span>
        <h2 id="contactHeading" class="contact-heading">
          {heading}
        </h2>
        <p class="contact-sub">
          {subheading}
        </p>

        <!-- Contact rows -->
        <div class="contact-rows">
          <a href={`tel:${SITE.phoneTel}`} class="crow">
            <span class="crow__icon">
              <Icon name="phone" size={18} strokeWidth={2} />
            </span>
            <div>
              <span class="crow__label">Telefon</span>
              <span class="crow__value">{SITE.phone}</span>
            </div>
          </a>

          <a href={`mailto:${SITE.email}`} class="crow">
            <span class="crow__icon">
              <Icon name="mail" size={18} strokeWidth={2} />
            </span>
            <div>
              <span class="crow__label">E-Mail</span>
              <span class="crow__value">{SITE.email}</span>
            </div>
          </a>

          <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="crow">
            <span class="crow__icon">
              <Icon name="whatsapp" size={18} fill="currentColor" stroke="none" strokeWidth={0} />
            </span>
            <div>
              <span class="crow__label">WhatsApp</span>
              <span class="crow__value">Nachricht senden</span>
            </div>
          </a>

          <div class="crow" style="cursor:default;">
            <span class="crow__icon">
              <Icon name="mapPin" size={18} strokeWidth={2} />
            </span>
            <div>
              <span class="crow__label">Adresse</span>
              <span class="crow__value">{SITE.address.street}, {SITE.address.zip} {SITE.address.city}</span>
            </div>
          </div>
        </div>

        <!-- Opening hours -->
        <div class="opening-hours">
          <p class="oh-title">Öffnungszeiten</p>
          <div class="oh-row">
            <span>Mo – Fr</span>
            <span>08:00 – 18:00 Uhr</span>
          </div>
          <div class="oh-row">
            <span>Sa</span>
            <span>09:00 – 13:00 Uhr</span>
          </div>
        </div>

        {showMap && (
          <div class="contact-map" data-aos="fade-up">
            <iframe
              title="Standort Limani Fliesenleger Mannheim"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2597.3!2d8.466!3d49.489!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4797cc1b4c4c4c4d%3A0x0!2sE7+13%2C+68159+Mannheim!5e0!3m2!1sde!2sde!4v1"
              width="100%"
              height="180"
              style="border:0; border-radius:0.75rem;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        )}
      </div>

      <!-- Right: Form card -->
      <div class="contact-form-card" data-aos="fade-left">

        <!-- Trust badge -->
        <div class="form-trust-badge">
          <Icon name="time" size={14} strokeWidth={2.5} />
          Wir antworten innerhalb von 24 Stunden
        </div>

        <form id="contactForm" class="contact-form" novalidate>
          <div class="form-row-2">
            <div class="fg">
              <label class="flabel" for="cf-vorname">Vorname *</label>
              <input class="finput" type="text" id="cf-vorname" name="vorname" required autocomplete="given-name" placeholder="Max" enterkeyhint="next" />
            </div>
            <div class="fg">
              <label class="flabel" for="cf-nachname">Nachname *</label>
              <input class="finput" type="text" id="cf-nachname" name="nachname" required autocomplete="family-name" placeholder="Mustermann" enterkeyhint="next" />
            </div>
          </div>

          <div class="fg">
            <label class="flabel" for="cf-telefon">Telefon *</label>
            <input class="finput" type="tel" id="cf-telefon" name="telefon" required autocomplete="tel" placeholder="0171 234 5678" enterkeyhint="next" />
          </div>

          <div class="fg">
            <label class="flabel" for="cf-email">E-Mail *</label>
            <input class="finput" type="email" id="cf-email" name="email" required autocomplete="email" placeholder="max@example.de" enterkeyhint="next" />
          </div>

          <div class="fg">
            <label class="flabel" for="cf-nachricht">
              Ihr Projekt
              <span class="flabel-opt">(optional)</span>
            </label>
            <textarea class="finput ftextarea" id="cf-nachricht" name="nachricht" rows="4" placeholder="Welche Arbeiten stehen an? Fläche, Wunschtermin, besondere Anforderungen…" enterkeyhint="send"></textarea>
          </div>

          <!-- Honeypot -->
          <input type="text" name="_gotcha" style="display:none;" tabindex="-1" autocomplete="off" />

          <button type="submit" id="cfSubmitBtn" class="cf-submit-btn">
            <Icon name="send" size={16} strokeWidth={2.5} />
            Nachricht absenden
          </button>

          <p id="cfSuccess" class="cf-feedback cf-feedback--ok" hidden>
            <Icon name="check" size={16} strokeWidth={2.5} />
            Ihre Nachricht wurde gesendet – wir melden uns bald.
          </p>
          <p id="cfError" class="cf-feedback cf-feedback--err" hidden>
            Fehler beim Senden. Rufen Sie uns direkt an:
            <a href="tel:+491733293668">0173 329 3668</a>
          </p>

          <p class="cf-privacy">
            * Pflichtfelder. Ihre Daten werden ausschließlich zur Anfragenbearbeitung verwendet.
          </p>
        </form>
      </div>

    </div>
  </div>
</section>

<style>
  .contact-section {
    background: var(--color-brand-primary);
    padding: 5rem 0;
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .contact-layout { grid-template-columns: 1fr 1fr; gap: 4.5rem; }
  }

  /* ── Left side ── */
  .section-label--accent {
    color: var(--color-brand-accent);
    margin-bottom: 0.875rem;
  }
  .section-label--accent::before {
    background: var(--color-brand-accent);
  }

  .contact-heading {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.025em;
    margin: 0 0 1rem;
    line-height: 1.15;
  }

  .contact-sub {
    color: rgba(255,255,255,0.72);
    font-size: 1rem;
    line-height: 1.75;
    margin: 0 0 2rem;
    max-width: 440px;
  }

  .contact-rows {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius-card);
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .crow {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1.125rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .crow:last-child { border-bottom: none; }
  a.crow:hover { background: rgba(255,255,255,0.06); }

  .crow__icon {
    width: 38px;
    height: 38px;
    border-radius: 0.625rem;
    background: rgba(232, 146, 42, 0.18);
    color: var(--color-brand-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .crow__label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.45);
    margin-bottom: 0.1rem;
  }

  .crow__value {
    display: block;
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(255,255,255,0.9);
  }

  .opening-hours {
    padding: 1rem 1.125rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .oh-title {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: rgba(255,255,255,0.45);
    margin: 0 0 0.5rem;
  }

  .oh-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.8);
    padding: 0.2rem 0;
  }
  .oh-row span:last-child { font-weight: 600; color: rgba(255,255,255,0.95); }

  .contact-map {
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.12);
  }

  /* ── Right side: form card ── */
  .contact-form-card {
    background: #fff;
    border-radius: 1.25rem;
    padding: 2.25rem;
    box-shadow: 0 24px 60px rgba(0,0,0,0.28);
  }

  .form-trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-brand-accent);
    background: rgba(232, 146, 42, 0.08);
    border: 1px solid rgba(232, 146, 42, 0.25);
    border-radius: 999px;
    padding: 0.35rem 0.875rem;
    margin-bottom: 1.5rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  .form-row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 480px) {
    .form-row-2 { grid-template-columns: 1fr; }
  }

  .fg {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .flabel {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-heading);
  }

  .flabel-opt {
    font-weight: 400;
    color: var(--color-text-muted);
    margin-left: 0.25rem;
  }

  .finput {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-border);
    border-radius: 0.625rem;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--color-text-heading);
    background: var(--color-surface-warm);
    transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    outline: none;
    appearance: none;
  }

  .finput:focus {
    border-color: var(--color-brand-accent);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(232, 146, 42, 0.15);
  }

  .finput.invalid {
    border-color: #dc2626;
  }

  .ftextarea {
    resize: none;
    min-height: 100px;
  }

  .cf-submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.9rem 1.75rem;
    background: var(--color-brand-accent);
    color: #fff;
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 1rem;
    border-radius: var(--radius-btn);
    border: none;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
    margin-top: 0.25rem;
  }

  .cf-submit-btn:hover {
    background: var(--color-brand-accent-dark);
    box-shadow: 0 6px 24px rgba(232, 146, 42, 0.4);
  }

  .cf-submit-btn:active {
    transform: scale(0.98);
  }

  .cf-submit-btn:disabled {
    opacity: 0.65;
    cursor: not-allowed;
    transform: none;
  }

  .cf-feedback {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    border-radius: 0.625rem;
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
  }
  .cf-feedback--ok {
    background: rgba(34, 197, 94, 0.1);
    color: #15803d;
    border: 1px solid rgba(34, 197, 94, 0.25);
  }
  .cf-feedback--err {
    background: rgba(239, 68, 68, 0.1);
    color: #b91c1c;
    border: 1px solid rgba(239, 68, 68, 0.25);
  }
  .cf-feedback--err a { color: inherit; font-weight: 700; }

  .cf-privacy {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }
</style>

<script>
  import { SITE } from '@/config/site';

  function initContactForm() {
    const form = document.getElementById('contactForm') as HTMLFormElement | null;
    if (!form) return;

    const submitBtn = document.getElementById('cfSubmitBtn') as HTMLButtonElement | null;
    const successMsg = document.getElementById('cfSuccess') as HTMLElement | null;
    const errorMsg = document.getElementById('cfError') as HTMLElement | null;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (!submitBtn) return;
      submitBtn.disabled = true;
      submitBtn.innerHTML = 'Wird gesendet…';

      successMsg?.setAttribute('hidden', '');
      errorMsg?.setAttribute('hidden', '');

      const formData = new FormData(form);
      const data: Record<string, string> = {};
      formData.forEach((value, key) => {
        if (key !== '_gotcha') data[key] = String(value);
      });

      if (formData.get('_gotcha')) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Nachricht absenden`;
        return;
      }

      try {
        const res = await fetch(SITE.workerUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          successMsg?.removeAttribute('hidden');
          form.reset();
          submitBtn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Gesendet`;
        } else {
          throw new Error('Server error');
        }
      } catch {
        errorMsg?.removeAttribute('hidden');
        submitBtn.disabled = false;
        submitBtn.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> Erneut senden`;
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactForm);
  } else {
    initContactForm();
  }
</script>
