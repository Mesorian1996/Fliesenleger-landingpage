---
/**
 * ReviewsSection
 * @category sections
 * @description Google reviews with star ratings and CTA to Google profile.
 */

import { SITE } from '@/config/site';
import Icon from '@/components/ui/Icon.astro';

const reviews = [
  {
    name: 'Donato de Tullio',
    badge: 'Local Guide',
    text: 'Sehr zufrieden mit der Arbeit von Limani Fliesenleger! Die Kommunikation war von Anfang an professionell und zuverlässig. Die Arbeiten wurden sauber, präzise und termingerecht ausgeführt. Man merkt sofort die hohe Qualität und die Liebe zum Detail.',
    date: 'Februar 2026',
  },
  {
    name: 'Julius Steinhäuser',
    badge: '',
    text: 'Absolut empfehlenswert! Herr Limani ist ein äußerst zuverlässiger, professioneller und freundlicher Handwerker. Die Arbeit wurde schnell, sauber und mit großer Sorgfalt ausgeführt – das Ergebnis hat meine Erwartungen sogar übertroffen.',
    date: 'Februar 2026',
  },
  {
    name: 'Nezir Neziri',
    badge: '',
    text: 'Ich bin äußerst zufrieden mit der Arbeit von Herrn Limani. Von der ersten Beratung bis zur finalen Umsetzung hat er durch seine Professionalität, Zuverlässigkeit und handwerkliche Präzision überzeugt. Die Fliesenarbeiten wurden sauber, präzise und in hoher Qualität ausgeführt.',
    date: 'Dezember 2025',
  },
  {
    name: 'Ivano T.',
    badge: '',
    text: 'Ich kann Limani Fliesenleger wärmstens empfehlen! Das Team ist unglaublich professionell, zuverlässig und kreativ. Die Arbeit ist von höchster Qualität, und das Ergebnis hat meine Erwartungen übertroffen. Ein super Service, der jeden Cent wert ist.',
    date: 'Februar 2026',
  },
  {
    name: 'Aleko Offiziell',
    badge: '',
    text: 'Wir haben eine jahrelange Erfahrung mit Firma Limani. Wir wurden nie enttäuscht. Immer wieder hat die Firma perfekte Arbeiten geliefert. Der Chef an sich ist einer der sympathischsten Menschen die ich je kennengelernt habe.',
    date: 'Februar 2026',
  },
  {
    name: 'Elias',
    badge: 'Local Guide',
    text: 'Echt super Arbeit! Man merkt sofort, dass hier Profis am Werk sind und keine 0815 Fliesenleger. Die Leute sind super nett, pünktlich und wissen genau, was sie tun. Kann ich definitiv nur weiterempfehlen!',
    date: 'Februar 2026',
  },
  {
    name: 'L.',
    badge: '',
    text: 'Schnell, sauber und sehr erfahren. Immer wieder gerne! Da legt man sein Vertrauen gerne in die Hände erfahrener Handwerker, bei solchen hervorragenden Ergebnissen!',
    date: 'Dezember 2025',
  },
];
---

<section class="py-20 bg-white" aria-labelledby="reviewsHeading">
  <div class="container">

    <!-- Header -->
    <div class="reviews-header" data-aos="fade-up">
      <span class="section-label">Google Bewertungen</span>
      <h2 id="reviewsHeading" style="font-size:clamp(1.75rem,3vw,2.5rem); margin:0 0 0.75rem; letter-spacing:-0.025em;">
        Das sagen unsere Kunden
      </h2>
      <div style="display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap;">
        <div style="display:flex; align-items:center; gap:0.375rem;">
          {Array(5).fill(null).map(() => (
            <Icon name="star" size={20} fill="#e8922a" stroke="none" strokeWidth={0} />
          ))}
        </div>
        <span style="font-size:1.125rem; font-weight:700; color:var(--color-text-heading);">5.0</span>
        <span style="font-size:0.9375rem; color:var(--color-text-muted);">auf Google</span>
      </div>
    </div>

    <!-- Reviews Grid -->
    <div class="reviews-grid" data-aos="fade-up">
      {reviews.map((r) => (
        <article class="review-card">
          <!-- Stars -->
          <div style="display:flex; gap:0.25rem; margin-bottom:1rem;" aria-label="5 von 5 Sternen">
            {Array(5).fill(null).map(() => (
              <Icon name="star" size={16} fill="#e8922a" stroke="none" strokeWidth={0} />
            ))}
          </div>

          <!-- Text -->
          <blockquote style="margin:0 0 1.25rem; font-size:0.9375rem; line-height:1.7; color:var(--color-text-body); font-style:italic;">
            &ldquo;{r.text}&rdquo;
          </blockquote>

          <!-- Author -->
          <div style="display:flex; align-items:center; gap:0.75rem;">
            <div style="width:36px; height:36px; border-radius:50%; background:var(--color-brand-primary); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span style="font-size:0.875rem; font-weight:700; color:#fff;">{r.name.charAt(0)}</span>
            </div>
            <div>
              <p style="font-size:0.875rem; font-weight:600; color:var(--color-text-heading); margin:0;">{r.name}</p>
              <p style="font-size:0.8rem; color:var(--color-text-muted); margin:0;">{r.badge ? `${r.badge} · ` : ''}{r.date}</p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div style="text-align:center; margin-top:2.5rem;" data-aos="fade-up">
      <a
        href={SITE.social.google}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline"
        aria-label="Alle Bewertungen auf Google ansehen"
      >
        <Icon name="time" size={16} strokeWidth={2} />
        Alle Bewertungen auf Google ansehen
      </a>
    </div>

  </div>
</section>

<style>
  .reviews-header {
    max-width: 520px;
    margin-bottom: 2.5rem;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .reviews-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .reviews-grid { grid-template-columns: repeat(4, 1fr); }
  }

  @media (min-width: 1280px) {
    .reviews-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .py-20 { padding-top: 5rem; padding-bottom: 5rem; }
</style>
