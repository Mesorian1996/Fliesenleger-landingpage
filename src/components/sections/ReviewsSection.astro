---
/**
 * ReviewsSection
 * @category sections
 * @description Google reviews with star ratings and CTA to Google profile.
 */

import { SITE } from '@/config/site';

const reviews = [
  {
    name: 'Thomas K.',
    location: 'Mannheim',
    text: 'Sehr saubere Arbeit, freundliche Beratung und schnelle Ausführung. Absolut zu empfehlen.',
    date: '2024-09',
  },
  {
    name: 'Sandra M.',
    location: 'Mannheim-Neckarau',
    text: 'Professionelle Arbeit. Herr Limani und sein Team haben unsere komplette Wohnung saniert. Alles top!',
    date: '2024-07',
  },
  {
    name: 'Michael R.',
    location: 'Ludwigshafen',
    text: 'Schnelle Terminvergabe, pünktliches Erscheinen und ein perfektes Ergebnis. Klare Empfehlung!',
    date: '2024-05',
  },
  {
    name: 'Christine B.',
    location: 'Mannheim-Lindenhof',
    text: 'Badsanierung top gemacht – bodengleiche Dusche, großformatige Fliesen, alles perfekt ausgerichtet. Danke!',
    date: '2024-03',
  },
];
---

<section class="py-20 bg-white" aria-labelledby="reviewsHeading">
  <div class="container">

    <!-- Header -->
    <div class="reviews-header" data-aos="fade-up">
      <span class="section-label">Google Bewertungen</span>
      <h2 id="reviewsHeading" style="font-size:clamp(1.75rem,3vw,2.5rem); margin:0 0 0.75rem; letter-spacing:-0.025em;">
        Das sagen unsere Kunden
      </h2>
      <div style="display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap;">
        <div style="display:flex; align-items:center; gap:0.375rem;">
          {Array(5).fill(null).map(() => (
            <svg width="20" height="20" viewBox="0 0 24 24" fill="#e8922a" aria-hidden="true">
              <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
            </svg>
          ))}
        </div>
        <span style="font-size:1.125rem; font-weight:700; color:var(--color-text-heading);">5.0</span>
        <span style="font-size:0.9375rem; color:var(--color-text-muted);">auf Google</span>
      </div>
    </div>

    <!-- Reviews Grid -->
    <div class="reviews-grid" data-aos="fade-up">
      {reviews.map((r) => (
        <article class="review-card">
          <!-- Stars -->
          <div style="display:flex; gap:0.25rem; margin-bottom:1rem;" aria-label="5 von 5 Sternen">
            {Array(5).fill(null).map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#e8922a" aria-hidden="true">
                <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
              </svg>
            ))}
          </div>

          <!-- Text -->
          <blockquote style="margin:0 0 1.25rem; font-size:0.9375rem; line-height:1.7; color:var(--color-text-body); font-style:italic;">
            &ldquo;{r.text}&rdquo;
          </blockquote>

          <!-- Author -->
          <div style="display:flex; align-items:center; gap:0.75rem;">
            <div style="width:36px; height:36px; border-radius:50%; background:var(--color-brand-primary); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
              <span style="font-size:0.875rem; font-weight:700; color:#fff;">{r.name.charAt(0)}</span>
            </div>
            <div>
              <p style="font-size:0.875rem; font-weight:600; color:var(--color-text-heading); margin:0;">{r.name}</p>
              <p style="font-size:0.8rem; color:var(--color-text-muted); margin:0;">{r.location}</p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div style="text-align:center; margin-top:2.5rem;" data-aos="fade-up">
      <a
        href={SITE.social.google}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-outline"
        aria-label="Alle Bewertungen auf Google ansehen"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12,8 12,12 14,14"/>
        </svg>
        Alle Bewertungen auf Google ansehen
      </a>
    </div>

  </div>
</section>

<style>
  .reviews-header {
    max-width: 520px;
    margin-bottom: 2.5rem;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .reviews-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .reviews-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .py-20 { padding-top: 5rem; padding-bottom: 5rem; }
</style>
