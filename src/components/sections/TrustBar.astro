---
/**
 * TrustBar
 * @category sections
 * @description Dark horizontal trust signal bar with key stats.
 */

interface Props {
  items?: { icon: string; text: string }[];
}

const defaultItems = [
  { icon: 'stars',        text: '5.0 auf Google' },
  { icon: 'projekte.svg', text: '1.000+ Projekte' },
  { icon: 'experience.svg',text: 'Inhaber mit 30+ Jahren Erfahrung' },
  { icon: 'regional.svg', text: 'Mannheim & Rhein-Neckar' },
];

const { items = defaultItems } = Astro.props;
---

<section class="trust-bar" aria-label="Vertrauenssignale">
  <div class="container">
    <ul class="trust-list" role="list">
      {items.map((item) => (
        <li class="trust-item">
          {item.icon === 'stars' ? (
            <span class="trust-stars" aria-label="5 von 5 Sternen">★★★★★</span>
          ) : (
            <img
              src={`/assets/icons/${item.icon}`}
              width="16"
              height="16"
              alt=""
              loading="lazy"
              class="trust-icon"
            />
          )}
          <span>{item.text}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .trust-list {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(255,255,255,0.9);
    white-space: nowrap;
  }

  .trust-item svg {
    color: var(--color-brand-accent);
    flex-shrink: 0;
  }

  .trust-icon {
    filter: brightness(0) invert(1);
    opacity: 0.85;
    flex-shrink: 0;
  }

  .trust-stars {
    color: var(--color-brand-accent);
    letter-spacing: -0.05em;
    font-size: 0.9375rem;
  }

  @media (max-width: 640px) {
    .trust-list {
      gap: 1rem 1.5rem;
    }
    .trust-item {
      font-size: 0.8125rem;
    }
  }
</style>
