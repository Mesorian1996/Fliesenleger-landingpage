---
/**
 * FunnelSection
 * @category sections
 * @description Premium 6-step conversion funnel. Dark split layout: pitch panel left, card right.
 *              Placed directly below Hero for maximum conversion.
 */

import { SITE } from '@/config/site';
import Icon from '@/components/ui/Icon.astro';
---

<section id="anfrage-funnel" class="funnel-section" aria-labelledby="funnelHeading">
  <div class="container">
    <div class="funnel-layout">

      <!-- ── Left: Pitch Panel ──────────────────────────────────── -->
      <div class="funnel-pitch" data-aos="fade-right">
        <span class="pitch-eyebrow">Kostenlos &amp; unverbindlich</span>

        <h2 id="funnelHeading" class="pitch-headline">
          Ihr persönliches<br />
          <em class="pitch-accent">Angebot in 2&nbsp;Minuten</em>
        </h2>

        <p class="pitch-sub">
          Kurze Fragen, ehrliches Angebot. Kein Verkaufsdruck, kein Kleingedrucktes.
        </p>

        <!-- Value props -->
        <ul class="pitch-props" aria-label="Ihre Vorteile">
          <li class="pitch-prop">
            <span class="prop-icon" aria-hidden="true">
              <Icon name="check" size={14} stroke="var(--color-brand-accent)" strokeWidth={3} />
            </span>
            <div>
              <strong>Antwort in 24 Stunden</strong>
              <span>Kein Warten auf einen Rückruf</span>
            </div>
          </li>
          <li class="pitch-prop">
            <span class="prop-icon" aria-hidden="true">
              <Icon name="check" size={14} stroke="var(--color-brand-accent)" strokeWidth={3} />
            </span>
            <div>
              <strong>Kostenlose Vor-Ort-Besichtigung</strong>
              <span>Transparente Kalkulation vor dem Auftrag</span>
            </div>
          </li>
          <li class="pitch-prop">
            <span class="prop-icon" aria-hidden="true">
              <Icon name="check" size={14} stroke="var(--color-brand-accent)" strokeWidth={3} />
            </span>
            <div>
              <strong>über 1.000 abgeschlossene Projekte</strong>
              <span>Inhaber mit 30+ Jahren Erfahrung als Fliesenleger</span>
            </div>
          </li>
        </ul>

        <!-- Google rating strip -->
        <div class="pitch-rating" aria-label="Google Bewertungen: 5 von 5 Sternen, 7 Bewertungen">
          <div class="rating-stars" aria-hidden="true">
            {Array(5).fill(null).map(() => (
              <Icon name="star" size={16} fill="#e8922a" stroke="none" strokeWidth={0} />
            ))}
          </div>
          <span class="rating-score">5,0</span>
          <span class="rating-label">auf Google</span>
        </div>
      </div>

      <!-- ── Right: Funnel Card ─────────────────────────────────── -->
      <div class="funnel-card" data-aos="fade-left">

        <!-- Card top accent bar -->
        <div class="card-accent-bar" aria-hidden="true"></div>

        <!-- Header (inside card) -->
        <div class="funnel-header">
          <p class="funnel-hook">Ihr Wunschprojekt ist nur ein paar Schritte entfernt.</p>
          <p class="funnel-subtitle">
            Wenige kurze Fragen – wir melden uns mit einem konkreten Angebot.
          </p>
        </div>

        <!-- Progress -->
        <div class="funnel-progress-wrap">
          <div class="funnel-dots" role="progressbar" aria-valuenow={1} aria-valuemin={1} aria-valuemax={6} aria-label="Fortschritt" id="funnelProgress">
            {[1,2,3,4,5,6].map(n => (
              <span class:list={['funnel-dot', n === 1 ? 'active' : '']} data-step={n} aria-hidden="true">
                {n}
              </span>
            ))}
          </div>
        </div>

        <!-- Steps -->
        <div id="funnelSteps">

          <!-- Step 1: Service -->
          <div class="funnel-step active" data-step="1">
            <h3 class="step-q">Welche Arbeiten sollen erledigt werden?</h3>
            <p class="step-hint">Mehrfachauswahl möglich</p>
            <div class="option-grid option-grid--6">
              {([
                { value: 'Fliesenarbeiten',   label: 'Fliesenarbeiten',   sub: 'Bad, Küche, Wände, Böden',    iconSrc: '/assets/icons/fliesenverlegung.svg' },
                { value: 'Badsanierung',      label: 'Badsanierung',      sub: 'Komplett oder Teilsanierung', iconSrc: '/assets/icons/badsanierung.svg' },
                { value: 'Bodenverlegung',    label: 'Bodenverlegung',    sub: 'Vinyl, Laminat, Parkett',     iconSrc: '/assets/icons/bodenverlegung.svg' },
                { value: 'Malerarbeiten',     label: 'Maler & Verputz',   sub: 'Wände, Decken, Spachtel',     iconSrc: '/assets/icons/malerarbeiten.svg' },
                { value: 'Trockenbau',        label: 'Trockenbau',        sub: 'Wände, Decken, Dämmung',      iconSrc: '/assets/icons/trockenbau.svg' },
                { value: 'Wohnungssanierung', label: 'Wohnungssanierung', sub: 'Komplett aus einer Hand',     iconSrc: '/assets/icons/wohnungssanierung.svg' },
              ] as const).map(opt => (
                <label class="option-card" data-for={opt.value}>
                  <input type="checkbox" name="leistung" value={opt.value} class="sr-only" />
                  <span class="option-icon" aria-hidden="true">
                    <img src={opt.iconSrc} width="30" height="30" alt="" loading="eager" />
                  </span>
                  <span class="option-label">{opt.label}</span>
                  <span class="option-sub">{opt.sub}</span>
                  <span class="option-check" aria-hidden="true">
                    <Icon name="check" size={12} stroke="white" strokeWidth={3} />
                  </span>
                </label>
              ))}
            </div>
          </div>

          <!-- Step 2: Area -->
          <div class="funnel-step" data-step="2">
            <h3 class="step-q">Wie groß ist die Fläche ungefähr?</h3>
            <p class="step-hint">Eine grobe Schätzung reicht</p>
            <div class="option-grid option-grid--4">
              {([
                { value: 'Unter 10 m²', label: 'Unter 10 m²', sub: 'z.B. Gäste-WC, kleine Küche', iconSrc: '/assets/icons/area.svg' },
                { value: '10–25 m²',    label: '10 – 25 m²',  sub: 'z.B. Bad, Küche, Flur',       iconSrc: '/assets/icons/area.svg' },
                { value: '25–50 m²',    label: '25 – 50 m²',  sub: 'z.B. Wohnzimmer, großes Bad', iconSrc: '/assets/icons/area.svg' },
                { value: 'Über 50 m²',  label: 'Über 50 m²',  sub: 'z.B. Wohnung, mehrere Räume', iconSrc: '/assets/icons/wohnungssanierung.svg' },
              ] as const).map(opt => (
                <label class="option-card option-card--radio" data-for={opt.value}>
                  <input type="radio" name="flaeche" value={opt.value} class="sr-only" />
                  <span class="option-icon" aria-hidden="true">
                    <img src={opt.iconSrc} width="30" height="30" alt="" loading="eager" />
                  </span>
                  <span class="option-label">{opt.label}</span>
                  <span class="option-sub">{opt.sub}</span>
                  <span class="option-check" aria-hidden="true">
                    <Icon name="check" size={12} stroke="white" strokeWidth={3} />
                  </span>
                </label>
              ))}
            </div>
          </div>

          <!-- Step 3: Timeline -->
          <div class="funnel-step" data-step="3">
            <h3 class="step-q">Wann sollen die Arbeiten stattfinden?</h3>
            <p class="step-hint">Wir planen Sie so schnell wie möglich ein</p>
            <div class="option-grid option-grid--3">
              {([
                { value: 'So schnell wie möglich', label: 'So schnell wie möglich', sub: 'Innerhalb von 1–2 Wochen', iconSrc: '/assets/icons/fast_appointment.svg' },
                { value: 'In 1–3 Monaten',         label: 'In 1 – 3 Monaten',        sub: 'In Ruhe planen',          iconSrc: '/assets/icons/planning.svg' },
                { value: 'Bin flexibel',            label: 'Bin flexibel',            sub: 'Richten uns nach Ihnen',  iconSrc: '/assets/icons/flexible_appointment.svg' },
              ] as const).map(opt => (
                <label class="option-card option-card--radio option-card--row" data-for={opt.value}>
                  <input type="radio" name="zeitrahmen" value={opt.value} class="sr-only" />
                  <span class="option-icon" aria-hidden="true">
                    <img src={opt.iconSrc} width="30" height="30" alt="" loading="lazy" />
                  </span>
                  <span class="option-text">
                    <span class="option-label">{opt.label}</span>
                    <span class="option-sub">{opt.sub}</span>
                  </span>
                  <span class="option-check" aria-hidden="true">
                    <Icon name="check" size={12} stroke="white" strokeWidth={3} />
                  </span>
                </label>
              ))}
            </div>
          </div>

          <!-- Step 4: Material -->
          <div class="funnel-step" data-step="4">
            <h3 class="step-q">Sollen wir das Material besorgen?</h3>
            <p class="step-hint">Wir arbeiten mit ausgewählten Partnern</p>
            <div class="option-grid option-grid--3">
              {([
                { value: 'Ja, Material durch Limani',  label: 'Ja, komplett durch euch', sub: 'Wir besorgen alles – bequem & zuverlässig', iconSrc: '/assets/icons/bring_material.svg' },
                { value: 'Nein, Material vorhanden',   label: 'Material vorhanden',       sub: 'Nur Handwerksleistung',                    iconSrc: '/assets/icons/wrong.svg' },
                { value: 'Noch unsicher',              label: 'Weiß ich noch nicht',      sub: 'Möchte ich gerne besprechen',              iconSrc: '/assets/icons/question.svg' },
              ] as const).map(opt => (
                <label class="option-card option-card--radio option-card--row" data-for={opt.value}>
                  <input type="radio" name="material" value={opt.value} class="sr-only" />
                  <span class="option-icon" aria-hidden="true">
                    <img src={opt.iconSrc} width="30" height="30" alt="" loading="lazy" />
                  </span>
                  <span class="option-text">
                    <span class="option-label">{opt.label}</span>
                    <span class="option-sub">{opt.sub}</span>
                  </span>
                  <span class="option-check" aria-hidden="true">
                    <Icon name="check" size={12} stroke="white" strokeWidth={3} />
                  </span>
                </label>
              ))}
            </div>
          </div>

          <!-- Step 5: Demolition -->
          <div class="funnel-step" data-step="5">
            <h3 class="step-q">Ist ein Rückbau notwendig?</h3>
            <p class="step-hint">z.B. alte Fliesen entfernen, Wände abbrechen</p>
            <div class="option-grid option-grid--3">
              {([
                { value: 'Ja, Rückbau nötig',  label: 'Ja, Rückbau nötig',  sub: 'Altes muss raus',        iconSrc: '/assets/icons/demolition.svg' },
                { value: 'Nein, kein Rückbau', label: 'Nein, kein Rückbau', sub: 'Fläche ist vorbereitet', iconSrc: '/assets/icons/wrong.svg' },
                { value: 'Bin mir unsicher',   label: 'Bin mir unsicher',   sub: 'Klären wir vor Ort',     iconSrc: '/assets/icons/question.svg' },
              ] as const).map(opt => (
                <label class="option-card option-card--radio option-card--row" data-for={opt.value}>
                  <input type="radio" name="rueckbau" value={opt.value} class="sr-only" />
                  <span class="option-icon" aria-hidden="true">
                    <img src={opt.iconSrc} width="30" height="30" alt="" loading="lazy" />
                  </span>
                  <span class="option-text">
                    <span class="option-label">{opt.label}</span>
                    <span class="option-sub">{opt.sub}</span>
                  </span>
                  <span class="option-check" aria-hidden="true">
                    <Icon name="check" size={12} stroke="white" strokeWidth={3} />
                  </span>
                </label>
              ))}
            </div>
          </div>

          <!-- Step 6: Contact -->
          <div class="funnel-step" data-step="6">
            <h3 class="step-q">Fast geschafft – wie erreichen wir Sie?</h3>
            <p class="step-hint">Wir melden uns innerhalb von 24 Stunden</p>

            <div class="funnel-summary" id="funnelSummary">
              <p class="summary-title">Ihre Angaben:</p>
              <div class="summary-tags" id="summaryTags"></div>
            </div>

            <div class="funnel-contact-form">
              <div class="funnel-form-row">
                <div class="funnel-field">
                  <label for="funnel-vorname" class="funnel-label">Vorname *</label>
                  <input type="text" id="funnel-vorname" name="Vorname" class="funnel-input" required autocomplete="given-name" placeholder="Max" enterkeyhint="next" />
                </div>
                <div class="funnel-field">
                  <label for="funnel-nachname" class="funnel-label">Nachname *</label>
                  <input type="text" id="funnel-nachname" name="Nachname" class="funnel-input" required autocomplete="family-name" placeholder="Mustermann" enterkeyhint="next" />
                </div>
              </div>
              <div class="funnel-form-row">
                <div class="funnel-field">
                  <label for="funnel-telefon" class="funnel-label">Telefon *</label>
                  <input type="tel" id="funnel-telefon" name="Telefon" class="funnel-input" required autocomplete="tel" placeholder="0173 1234567" enterkeyhint="next" />
                </div>
                <div class="funnel-field">
                  <label for="funnel-email" class="funnel-label">E-Mail *</label>
                  <input type="email" id="funnel-email" name="Email" class="funnel-input" required autocomplete="email" placeholder="max@beispiel.de" enterkeyhint="next" />
                </div>
              </div>
              <div class="funnel-field">
                <label for="funnel-notiz" class="funnel-label">
                  Ergänzung
                  <span class="funnel-label-optional">(optional)</span>
                </label>
                <textarea id="funnel-notiz" name="Nachricht" class="funnel-input funnel-textarea" rows={2} maxlength={400} placeholder="z.B. Adresse, besondere Wünsche …" enterkeyhint="send"></textarea>
              </div>
            </div>
          </div>

        </div><!-- /funnelSteps -->

        <!-- Navigation -->
        <div class="funnel-nav" id="funnelNav">
          <button type="button" id="funnelBack" class="funnel-btn-back" style="visibility:hidden;" aria-label="Zurück">
            <Icon name="chevronLeft" size={15} strokeWidth={2.5} />
            Zurück
          </button>
          <button type="button" id="funnelNext" class="btn-primary funnel-btn-cta" aria-label="Weiter" disabled>
            Weiter
            <Icon name="chevronRight" size={15} strokeWidth={2.5} />
          </button>
          <button type="button" id="funnelSubmit" class="btn-primary funnel-btn-cta" aria-label="Angebot anfragen" style="display:none;">
            Kostenloses Angebot anfragen
            <Icon name="check" size={15} strokeWidth={2.5} />
          </button>
        </div>

        <p id="funnelHint" class="funnel-hint" role="alert" aria-live="polite"></p>

        <!-- Success -->
        <div id="funnelSuccess" style="display:none; text-align:center; padding:2.5rem 0;">
          <div class="funnel-success-icon">
            <Icon name="check" size={28} stroke="rgba(34,197,94,0.9)" strokeWidth={2.5} />
          </div>
          <h3 style="font-size:1.375rem; margin:0 0 0.625rem;">Anfrage erfolgreich gesendet</h3>
          <p style="color:var(--color-text-muted); margin:0 0 1.5rem;">Vielen Dank – wir melden uns innerhalb von 24 Stunden bei Ihnen.</p>
          <button type="button" id="funnelReset" class="btn-outline" style="font-size:0.875rem;">Neue Anfrage starten</button>
        </div>

        <!-- Error -->
        <div id="funnelError" style="display:none; text-align:center; padding:1rem 0;">
          <p style="color:#dc2626; font-size:0.9375rem;">
            Verbindungsfehler. Bitte versuchen Sie es erneut oder rufen Sie uns an:
            <a href={`tel:${SITE.phoneTel}`} style="color:#dc2626; font-weight:600;">{SITE.phone}</a>
          </p>
        </div>

      </div><!-- /funnel-card -->
    </div><!-- /funnel-layout -->

    <!-- Trust signals — outside card, full-width under funnel -->
    <div class="funnel-trust-bar" id="funnelTrust">
      <span class="trust-item">
        <Icon name="lock" size={13} strokeWidth={2} />
        SSL-verschlüsselt
      </span>
      <span class="trust-item">
        <img src="/assets/icons/001-24-hours.svg" width="15" height="15" alt="" loading="lazy" class="funnel-trust-icon" />
        Antwort in 24 Stunden
      </span>
      <span class="trust-item">
        <Icon name="shield" size={13} strokeWidth={2} />
        Keine Weitergabe
      </span>
    </div>

  </div>
</section>

<style>
  /* Anchor offset — prevents sticky navbar from covering the section */
  #anfrage-funnel {
    scroll-margin-top: 5rem;
  }

  /* ── Section ───────────────────────────────────────────────── */
  .funnel-section {
    padding: var(--spacing-section) 0;
    background:
      radial-gradient(ellipse 70% 60% at 15% 50%, rgba(232,146,42,0.08) 0%, transparent 60%),
      linear-gradient(160deg, #1a120b 0%, var(--color-brand-primary) 40%, #160f08 100%);
    position: relative;
    overflow: hidden;
  }

  /* Subtle texture overlay */
  .funnel-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 80% 20%, rgba(232,146,42,0.06) 0%, transparent 50%),
      radial-gradient(circle at 10% 80%, rgba(232,146,42,0.04) 0%, transparent 40%);
    pointer-events: none;
  }

  /* ── Two-column layout ─────────────────────────────────────── */
  .funnel-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    position: relative;
    z-index: 1;
  }

  @media (min-width: 1024px) {
    .funnel-layout {
      grid-template-columns: 1fr 1.15fr;
      gap: 5rem;
      align-items: start;
    }
  }

  /* ── Pitch Panel ───────────────────────────────────────────── */
  .funnel-pitch {
    color: #fff;
    padding-top: 0.5rem;
  }

  .pitch-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-brand-accent);
    margin-bottom: 1.25rem;
  }

  .pitch-headline {
    font-size: clamp(1.875rem, 4vw, 2.875rem);
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0 0 1.125rem;
  }

  .pitch-accent {
    font-style: normal;
    color: var(--color-brand-accent);
  }

  .pitch-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.65;
    margin: 0 0 2rem;
    max-width: 380px;
  }

  /* Value props */
  .pitch-props {
    list-style: none;
    margin: 0 0 2.25rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .pitch-prop {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .prop-icon {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(232,146,42,0.15);
    border: 1px solid rgba(232,146,42,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .pitch-prop div {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .pitch-prop strong {
    font-size: 0.9375rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
  }

  .pitch-prop span {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.4;
  }

  /* Rating strip */
  .pitch-rating {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    padding: 0.875rem 1.125rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.75rem;
    backdrop-filter: blur(4px);
  }

  .rating-stars {
    display: flex;
    gap: 0.2rem;
  }

  .rating-score {
    font-size: 1.0625rem;
    font-weight: 800;
    color: #fff;
  }

  .rating-label {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.55);
  }

  /* ── Card ──────────────────────────────────────────────────── */
  .funnel-card {
    background: #ffffff;
    border-radius: 1.375rem;
    box-shadow:
      0 0 0 1px rgba(0,0,0,0.06),
      0 8px 32px rgba(0,0,0,0.2),
      0 40px 80px -20px rgba(0,0,0,0.25);
    overflow: hidden;
    position: relative;
  }

  .card-accent-bar {
    height: 4px;
    background: linear-gradient(90deg, var(--color-brand-accent) 0%, #f5b557 50%, var(--color-brand-accent) 100%);
  }

  .funnel-card > *:not(.card-accent-bar) {
    padding-left: clamp(1.25rem, 4vw, 2.25rem);
    padding-right: clamp(1.25rem, 4vw, 2.25rem);
  }

  /* ── Header ────────────────────────────────────────────────── */
  .funnel-header {
    padding-top: 1.375rem;
    padding-bottom: 0;
    margin-bottom: 1.125rem;
  }

  .funnel-hook {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text-heading);
    margin: 0 0 0.25rem;
    line-height: 1.4;
  }

  .funnel-subtitle {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* ── Progress ──────────────────────────────────────────────── */
  .funnel-progress-wrap {
    margin-bottom: 1.5rem;
  }

  .funnel-dots {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Connecting line behind dots */
  .funnel-dots::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 14px;
    right: 14px;
    height: 2px;
    background: #e8e4df;
    transform: translateY(-50%);
    z-index: 0;
  }

  .funnel-dot {
    position: relative;
    z-index: 1;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #f0ece7;
    color: var(--color-text-muted);
    font-size: 0.7rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.25s ease, color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .funnel-dot.active {
    background: var(--color-brand-accent);
    color: #fff;
    transform: scale(1.15);
    box-shadow: 0 2px 12px rgba(232,146,42,0.35);
  }

  .funnel-dot.done {
    background: var(--color-brand-primary);
    color: #fff;
  }

  /* ── Steps ─────────────────────────────────────────────────── */
  .funnel-step { display: none; }
  .funnel-step.active {
    display: block;
    animation: fStepIn 0.35s ease both;
  }

  @keyframes fStepIn {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .step-q {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-heading);
    margin: 0 0 0.3rem;
    letter-spacing: -0.01em;
  }

  .step-hint {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin: 0 0 1.125rem;
  }

  /* ── Option grids ──────────────────────────────────────────── */
  .option-grid {
    display: grid;
    gap: 0.5rem;
  }

  .option-grid--6 { grid-template-columns: repeat(2, 1fr); }
  .option-grid--4 { grid-template-columns: repeat(2, 1fr); }
  .option-grid--3 { grid-template-columns: 1fr; }

  @media (min-width: 540px) {
    .option-grid--6 { grid-template-columns: repeat(3, 1fr); }
    .option-grid--3 { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── Option card — vertical ────────────────────────────────── */
  .option-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.3rem;
    padding: 0.875rem 0.75rem;
    background: #faf8f5;
    border: 2px solid transparent;
    border-radius: 0.875rem;
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }

  .option-card:hover {
    border-color: rgba(232,146,42,0.35);
    background: #fff;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(12,27,46,0.07);
  }

  .option-card.selected {
    border-color: var(--color-brand-accent);
    background: rgba(232,146,42,0.05);
    box-shadow: 0 4px 16px rgba(232,146,42,0.12);
  }

  /* ── Option card — row (now also vertical/centered) ───────── */
  .option-card--row {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.3rem;
    padding: 0.875rem 0.75rem;
  }

  .option-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.15rem;
  }

  /* ── Option icon ───────────────────────────────────────────── */
  .option-icon {
    width: 40px;
    height: 40px;
    border-radius: 0.625rem;
    background: rgba(232,146,42,0.09);
    color: var(--color-brand-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s ease;
    margin-bottom: 0.125rem;
  }

  .option-card--row .option-icon { margin-bottom: 0; }
  .option-card.selected .option-icon { background: rgba(232,146,42,0.18); }

  /* ── Option text ───────────────────────────────────────────── */
  .option-label {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-text-heading);
    line-height: 1.3;
  }

  .option-sub {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  /* ── Selected checkmark ────────────────────────────────────── */
  .option-check {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: var(--color-brand-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: scale(0.4);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
  }

  .option-card.selected .option-check {
    opacity: 1;
    transform: scale(1);
  }

  /* ── Summary (step 6) ──────────────────────────────────────── */
  @media (max-width: 767px) {
    .funnel-summary { display: none; }
  }

  .funnel-summary {
    background: #faf8f5;
    border-radius: 0.75rem;
    padding: 0.875rem 1rem;
    margin-bottom: 1.25rem;
  }

  .summary-title {
    font-size: 0.71rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem;
  }

  .summary-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .summary-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.2rem 0.625rem;
    background: rgba(232,146,42,0.1);
    border: 1px solid rgba(232,146,42,0.25);
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-text-body);
  }

  .summary-tag-label {
    font-weight: 700;
    color: var(--color-brand-accent);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* ── Contact form ──────────────────────────────────────────── */
  .funnel-contact-form {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .funnel-form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.875rem;
  }

  @media (min-width: 480px) {
    .funnel-form-row { grid-template-columns: 1fr 1fr; }
  }

  .funnel-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .funnel-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-heading);
  }

  .funnel-label-optional {
    font-weight: 400;
    color: var(--color-text-muted);
    margin-left: 0.25rem;
  }

  .funnel-textarea { resize: none; min-height: 72px; }

  /* ── Navigation ────────────────────────────────────────────── */
  .funnel-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1.375rem;
    padding-bottom: 0;
    gap: 1rem;
  }

  .funnel-btn-back {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    transition: color 0.15s ease;
    font-family: var(--font-body);
  }
  .funnel-btn-back:hover { color: var(--color-text-heading); }

  .funnel-btn-cta { margin-left: auto; }

  .funnel-btn-cta:disabled {
    background: #e8e3de;
    color: #b0a898;
    box-shadow: none;
    transform: none;
    cursor: default;
    pointer-events: none;
  }

  /* ── Validation hint ───────────────────────────────────────── */
  .funnel-hint {
    font-size: 0.875rem;
    color: #dc2626;
    min-height: 1.25rem;
    margin-top: 0.5rem;
    text-align: center;
  }

  /* ── Trust bar — outside card, on dark section bg ─────────── */
  .funnel-trust-bar {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem 1.75rem;
    padding-top: 1.75rem;
    margin-top: 1.75rem;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .funnel-trust-bar .trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(255,255,255,0.4);
  }

  .funnel-trust-bar .trust-item svg { opacity: 0.5; flex-shrink: 0; }
  .funnel-trust-icon { filter: brightness(0) invert(1); opacity: 0.5; flex-shrink: 0; }

  /* ── Success ───────────────────────────────────────────────── */
  .funnel-success-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(34,197,94,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
  }

  /* ── Inputs ────────────────────────────────────────────────── */
  .funnel-input {
    padding: 0.75rem 0.9rem;
    border: 1.5px solid #e8e4df;
    border-radius: 0.625rem;
    font-size: 16px;
    color: var(--color-text-heading);
    background: #ffffff;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    font-family: var(--font-body);
    width: 100%;
  }

  .funnel-input:focus {
    outline: none;
    border-color: var(--color-brand-accent);
    box-shadow: 0 0 0 3px rgba(232,146,42,0.12);
  }

  .funnel-input::placeholder { color: var(--color-text-muted); opacity: 0.7; }

  .funnel-input.invalid {
    border-color: #dc2626;
    box-shadow: 0 0 0 3px rgba(220,38,38,0.1);
  }

  /* ── a11y ──────────────────────────────────────────────────── */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
  }

  /* ── Mobile: pitch panel compact ──────────────────────────── */
  @media (max-width: 1023px) {
    .pitch-sub { max-width: 100%; }
    .pitch-props { gap: 0.75rem; }
    .pitch-headline { font-size: clamp(1.625rem, 5vw, 2.25rem); }
  }

  /* ── Mobile: compact option cards (all steps) ─────────────── */
  @media (max-width: 479px) {
    .option-card {
      padding: 0.75rem 0.5rem;
      gap: 0.25rem;
    }
    .option-icon {
      width: 34px;
      height: 34px;
      border-radius: 0.5rem;
    }
    .option-label { font-size: 0.75rem; }
    .option-sub   { font-size: 0.65rem; }
  }
</style>

<script is:inline define:vars={{ workerUrl: SITE.workerUrl }}>
  (function () {
    'use strict';

    const TOTAL = 6;
    const stepsContainer = document.getElementById('funnelSteps');
    if (!stepsContainer) return;

    const btnNext        = document.getElementById('funnelNext');
    const btnBack        = document.getElementById('funnelBack');
    const btnSubmit      = document.getElementById('funnelSubmit');
    const hint           = document.getElementById('funnelHint');
    const successEl      = document.getElementById('funnelSuccess');
    const errorEl        = document.getElementById('funnelError');
    const resetBtn       = document.getElementById('funnelReset');
    const navEl          = document.getElementById('funnelNav');
    const trustEl        = document.getElementById('funnelTrust');
    const summaryTags    = document.getElementById('summaryTags');
    const dots           = document.querySelectorAll('.funnel-dot');

    let current = 1;

    function getStep(n) {
      return stepsContainer.querySelector(`.funnel-step[data-step="${n}"]`);
    }

    function showStep(n) {
      document.querySelectorAll('.funnel-step').forEach(s => s.classList.remove('active'));
      const step = getStep(n);
      if (step) step.classList.add('active');

      dots.forEach((dot, i) => {
        dot.classList.remove('active', 'done');
        if (i + 1 === n)      dot.classList.add('active');
        else if (i + 1 < n)   dot.classList.add('done');
      });

      if (btnBack) btnBack.style.visibility = n === 1 ? 'hidden' : 'visible';

      if (btnNext && btnSubmit) {
        if (n === TOTAL) {
          btnNext.style.display   = 'none';
          btnSubmit.style.display = 'inline-flex';
          buildSummary();
        } else if (n >= 2 && n <= 5) {
          btnNext.style.display   = 'none';
          btnSubmit.style.display = 'none';
        } else {
          const hasSelection = getStep(1)?.querySelectorAll('input[name="leistung"]:checked').length > 0;
          btnNext.style.display = 'inline-flex';
          btnNext.disabled      = !hasSelection;
          btnSubmit.style.display = 'none';
        }
      }

      clearHint();
    }

    function clearHint()      { if (hint) hint.textContent = ''; }
    function showHint(msg)    { if (hint) hint.textContent = msg; }

    function validateStep(n) {
      if (n === 1) {
        const checked = getStep(1)?.querySelectorAll('input[name="leistung"]:checked') || [];
        if (checked.length === 0) { showHint('Bitte wählen Sie mindestens eine Leistung aus.'); return false; }
      }
      if (n >= 2 && n <= 5) {
        const radios = getStep(n)?.querySelectorAll('input[type="radio"]') || [];
        if (radios.length > 0 && !Array.from(radios).some(r => r.checked)) {
          showHint('Bitte wählen Sie eine Option aus.'); return false;
        }
      }
      if (n === TOTAL) {
        const fields = ['funnel-vorname', 'funnel-nachname', 'funnel-telefon', 'funnel-email'];
        let valid = true;
        fields.forEach(id => {
          const el = document.getElementById(id);
          if (!el) return;
          el.classList.remove('invalid');
          if (!el.value.trim()) { el.classList.add('invalid'); valid = false; }
        });
        const emailEl = document.getElementById('funnel-email');
        if (emailEl && emailEl.value.trim() && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value.trim())) {
          emailEl.classList.add('invalid'); valid = false;
        }
        if (!valid) { showHint('Bitte füllen Sie alle Pflichtfelder korrekt aus.'); return false; }
      }
      return true;
    }

    function buildSummary() {
      if (!summaryTags) return;
      summaryTags.innerHTML = '';
      const d = collectData();
      [
        { label: 'Leistung',  val: d.leistung },
        { label: 'Fläche',    val: d.flaeche },
        { label: 'Zeitraum',  val: d.zeitrahmen },
        { label: 'Material',  val: d.material },
        { label: 'Rückbau',   val: d.rueckbau },
      ].forEach(({ label, val }) => {
        if (!val) return;
        const tag = document.createElement('span');
        tag.className = 'summary-tag';
        const safe = document.createElement('div');
        safe.textContent = val;
        tag.innerHTML = `<span class="summary-tag-label">${label}:</span> ${safe.innerHTML}`;
        summaryTags.appendChild(tag);
      });
    }

    function collectData() {
      const leistungen = Array.from(
        stepsContainer.querySelectorAll('input[name="leistung"]:checked')
      ).map(i => i.value);
      const getRadio = name => {
        const el = stepsContainer.querySelector(`input[name="${name}"]:checked`);
        return el ? el.value : '';
      };
      return {
        leistung:   leistungen.join(', '),
        flaeche:    getRadio('flaeche'),
        zeitrahmen: getRadio('zeitrahmen'),
        material:   getRadio('material'),
        rueckbau:   getRadio('rueckbau'),
        vorname:    document.getElementById('funnel-vorname')?.value.trim()  || '',
        nachname:   document.getElementById('funnel-nachname')?.value.trim() || '',
        telefon:    document.getElementById('funnel-telefon')?.value.trim()  || '',
        email:      document.getElementById('funnel-email')?.value.trim()    || '',
        notiz:      document.getElementById('funnel-notiz')?.value.trim()    || '',
      };
    }

    function scrollToFunnel() {
      const navH = document.querySelector('.navbar')?.offsetHeight || 80;
      const isMobile = window.innerWidth < 1024;
      const target = isMobile
        ? document.querySelector('.funnel-card')
        : document.getElementById('anfrage-funnel');
      if (!target) return;
      window.scrollTo({ top: target.getBoundingClientRect().top + window.scrollY - navH - 8, behavior: 'smooth' });
    }

    async function submitFunnel() {
      const data = collectData();
      if (btnSubmit) {
        btnSubmit.disabled = true;
        btnSubmit.innerHTML = 'Wird gesendet…';
      }
      if (errorEl) errorEl.style.display = 'none';

      const body = {
        Vorname: data.vorname, Nachname: data.nachname,
        Telefon: data.telefon, Email: data.email,
        Leistung: data.leistung, Flaeche: data.flaeche,
        Zeitrahmen: data.zeitrahmen, Material: data.material,
        Rueckbau: data.rueckbau, Nachricht: data.notiz || '',
        source: 'Funnel',
      };

      try {
        const res = await fetch(workerUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (res.ok) { showSuccess(); }
        else        { showError(); }
      } catch { showError(); }
    }

    function showSuccess() {
      stepsContainer.style.display = 'none';
      if (navEl)       navEl.style.display       = 'none';
      if (trustEl)     trustEl.style.display      = 'none';
      const progressWrap = document.querySelector('.funnel-progress-wrap');
      if (progressWrap) progressWrap.style.display = 'none';
      if (hint)        hint.style.display         = 'none';
      if (errorEl)     errorEl.style.display      = 'none';
      if (successEl)   successEl.style.display    = 'block';
      scrollToFunnel();
    }

    function showError() {
      if (errorEl) errorEl.style.display = 'block';
      if (btnSubmit) {
        btnSubmit.disabled = false;
        btnSubmit.innerHTML = 'Erneut versuchen';
      }
    }

    function resetFunnel() {
      stepsContainer.querySelectorAll('input, textarea').forEach(el => {
        if (el.type === 'checkbox' || el.type === 'radio') el.checked = false;
        else el.value = '';
        el.classList.remove('invalid');
      });
      stepsContainer.querySelectorAll('.option-card').forEach(c => c.classList.remove('selected'));
      stepsContainer.style.display = '';
      if (navEl)     navEl.style.display   = '';
      if (trustEl)   trustEl.style.display = '';
      const progressWrap = document.querySelector('.funnel-progress-wrap');
      if (progressWrap) progressWrap.style.display = '';
      if (hint)      hint.style.display    = '';
      if (successEl) successEl.style.display = 'none';
      if (errorEl)   errorEl.style.display   = 'none';
      current = 1;
      showStep(1);
      scrollToFunnel();
    }

    // Step 1: checkbox — enable Weiter on first selection
    getStep(1)?.querySelectorAll('input[name="leistung"]').forEach(cb => {
      cb.addEventListener('change', () => {
        if (current !== 1) return;
        const has = getStep(1)?.querySelectorAll('input[name="leistung"]:checked').length > 0;
        if (btnNext) btnNext.disabled = !has;
        const card = cb.closest('.option-card');
        if (card) card.classList.toggle('selected', cb.checked);
      });
    });

    // Steps 2–5: radio — auto-advance
    for (let i = 2; i <= 5; i++) {
      getStep(i)?.querySelectorAll('input[type="radio"]').forEach(radio => {
        radio.addEventListener('change', () => {
          getStep(i)?.querySelectorAll('.option-card').forEach(c => c.classList.remove('selected'));
          const card = radio.closest('.option-card');
          if (card) card.classList.add('selected');
          setTimeout(() => {
            if (current === i && current < TOTAL) {
              current++;
              showStep(current);
              scrollToFunnel();
            }
          }, 300);
        });
      });
    }

    btnNext?.addEventListener('click', () => {
      if (!validateStep(current)) return;
      if (current < TOTAL) { current++; showStep(current); scrollToFunnel(); }
    });

    btnBack?.addEventListener('click', () => {
      if (current > 1) { current--; showStep(current); }
    });

    btnSubmit?.addEventListener('click', () => {
      if (!validateStep(TOTAL)) return;
      submitFunnel();
    });

    resetBtn?.addEventListener('click', resetFunnel);

    stepsContainer.addEventListener('keydown', e => {
      if (e.key === 'Enter' && e.target.tagName !== 'TEXTAREA') {
        e.preventDefault();
        if (current < TOTAL) btnNext?.click();
        else btnSubmit?.click();
      }
    });

    stepsContainer.addEventListener('input', e => {
      if (e.target.classList.contains('invalid')) e.target.classList.remove('invalid');
      clearHint();
    });

    showStep(1);
  })();
</script>
