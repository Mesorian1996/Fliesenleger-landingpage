---
/**
 * PartnerSection
 * @category sections
 * @description Material partners — colored logo cards with lift effect.
 */

const partners = [
  { name: 'ARDEX',       logo: '/assets/images/partner-ardex.svg',     href: '#' },
  { name: 'Keramundo',   logo: '/assets/images/partner-keramundo.svg', href: '#' },
  { name: 'Arte Muri',   logo: '/assets/images/partner-artemuri.png',  href: '#' },
  { name: 'MEGA Gruppe', logo: '/assets/images/partner-mega.svg',      href: '#' },
];
---

<section class="partner-section" aria-labelledby="partnerHeading">
  <div class="container">

    <div class="partner-header" data-aos="fade-up">
      <span class="section-label">Unsere Partner</span>
      <h2 id="partnerHeading">Qualität, die man sieht</h2>
      <p class="partner-intro">
        Unsere regionalen Materialpartner versorgen uns täglich mit erstklassigen Produkten –
        damit dein Wunschprojekt nicht nur entsteht, sondern bleibt.
      </p>
    </div>

    <div class="partner-grid" data-aos="fade-up">
      {partners.map(p => (
        <a
          href={p.href}
          class="partner-card"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${p.name} – Partnerseite öffnen`}
        >
          <img
            src={p.logo}
            alt={p.name}
            loading="lazy"
            decoding="async"
          />
          <span class="partner-name">{p.name}</span>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .partner-section {
    padding: 4rem 0 4.5rem;
    background: var(--color-surface-warm, #faf9f7);
  }

  .partner-header {
    max-width: 560px;
    margin-bottom: 2.5rem;
  }

  .partner-header h2 {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text-heading);
    margin: 0.375rem 0 1rem;
  }

  .partner-intro {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin: 0;
    max-width: 520px;
  }

  .partner-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .partner-grid { grid-template-columns: repeat(4, 1fr); gap: 1rem; }
  }

  .partner-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.75rem 1.5rem 1.5rem;
    min-height: 110px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    background: #fff;
    text-decoration: none;
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  }

  .partner-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    border-color: rgba(232,146,42,0.25);
  }

  .partner-card img {
    max-height: 38px;
    max-width: 120px;
    width: auto;
    object-fit: contain;
  }

  .partner-name {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  @media (max-width: 639px) {
    .partner-card {
      padding: 1.25rem 1rem 1rem;
      min-height: 90px;
      gap: 0.5rem;
    }
    .partner-card img {
      max-height: 28px;
      max-width: 100px;
    }
  }
</style>
