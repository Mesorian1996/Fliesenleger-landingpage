---
/**
 * LocalSeoSection
 * @category sections
 * @description Regional presence — map visualization + bento service cards.
 */

const services = [
  { label: 'Fliesen',           sub: 'Bad, Küche & Außen',        icon: '/assets/icons/fliesenverlegung.svg',  href: '/fliesenarbeiten-mannheim' },
  { label: 'Badsanierung',      sub: 'Komplett oder Teilsanierung', icon: '/assets/icons/badsanierung.svg',    href: '/badsanierung-mannheim' },
  { label: 'Malerarbeiten',     sub: 'Verputz & Anstrich',         icon: '/assets/icons/malerarbeiten.svg',    href: '/malerarbeiten-mannheim' },
  { label: 'Trockenbau',        sub: 'Wände & Decken',             icon: '/assets/icons/trockenbau.svg',       href: '/trockenbauarbeiten-mannheim' },
  { label: 'Boden',             sub: 'Parkett, Vinyl & Laminat',   icon: '/assets/icons/bodenverlegung.svg',   href: '/bodenarbeiten-mannheim' },
  { label: 'Sanierung',         sub: 'Alle Gewerke koordiniert',   icon: '/assets/icons/wohnungssanierung.svg', href: '/wohnungssanierung-mannheim' },
];
---

<section class="local-section" aria-labelledby="localHeading">
  <div class="container">

    <!-- Hook Header -->
    <div class="local-hook" data-aos="fade-up">
      <span class="section-label">Mannheim & Rhein-Neckar</span>
      <h2 id="localHeading">
        Wir sind von hier.<br>
        <em>Das merkt man.</em>
      </h2>
    </div>

    <!-- Main Grid -->
    <div class="local-grid" data-aos="fade-up">

      <!-- Left: Copy + Service Bento -->
      <div class="local-copy">

        <p class="local-lead">
          Du rufst an und der Chef geht ran. Wir besprechen direkt,
          was du brauchst, wann wir kommen können und was das ungefähr kostet.
          Kein Rückruf in drei Tagen, keine Weitervermittlung.
        </p>

        <p>
          Seit 2017 fahren wir täglich durch Mannheim.
          <strong>Neckarau, Feudenheim, Käfertal, Lindenhof, Rheinau.</strong>
          Wir kennen diese Stadtteile und ihre Bauten. Wie sie konstruiert sind,
          was sie verlangen. Beim ersten Gespräch kriegst du bereits
          eine ehrliche Einschätzung.
        </p>

        <p>
          Nach <strong>Ludwigshafen, Heidelberg, Viernheim und Weinheim</strong>
          fahren wir genauso selbstverständlich wie nach Mannheim.
          Anfahrt ist kein Thema. Und nach dem Auftrag sind wir
          genauso erreichbar wie davor.
        </p>

        <!-- Service Bento Grid -->
        <div class="service-bento-label">Unsere Leistungen</div>
        <div class="service-bento">
          {services.map(s => (
            <a href={s.href} class="service-bento-card">
              <img src={s.icon} width="24" height="24" alt="" loading="lazy" class="bento-icon" />
              <span class="bento-label">{s.label}</span>
              <span class="bento-sub">{s.sub}</span>
            </a>
          ))}
        </div>

        <a href="#anfrage-funnel" class="btn-primary local-cta">
          Jetzt unverbindlich anfragen
        </a>

      </div>

      <!-- Right: SVG Map -->
      <div class="local-map-wrap" data-aos="fade-left">
        <div class="map-card">

          <svg
            viewBox="-20 -20 410 380"
            xmlns="http://www.w3.org/2000/svg"
            class="mannheim-svg"
            role="img"
            aria-label="Mannheim Stadtteile – Einsatzgebiet Limani"
          >
            <!-- Rhine -->
            <path class="river river--rhein"
              d="M 65,340 C 44,280 38,220 40,165 C 42,110 46,60 52,15" />
            <text class="river-label" x="20" y="230"
              transform="rotate(-78 20 230)">Rhein</text>

            <!-- Neckar -->
            <path class="river river--neckar"
              d="M 350,222 C 285,207 215,188 165,174 C 125,163 82,146 48,128" />
            <text class="river-label" x="218" y="178"
              transform="rotate(-7 218 178)">Neckar</text>

            <!-- ── Districts ─────────────────────────────── -->

            <g class="dp">
              <circle cx="62" cy="35" r="4.5"/>
              <text x="62" y="25" text-anchor="middle">Sandhofen</text>
            </g>

            <g class="dp">
              <circle cx="146" cy="91" r="4.5"/>
              <text x="138" y="83" text-anchor="end">Waldhof</text>
            </g>

            <g class="dp">
              <circle cx="188" cy="140" r="4.5"/>
              <text x="197" y="133" text-anchor="start">Käfertal</text>
            </g>

            <g class="dp">
              <circle cx="240" cy="113" r="4.5"/>
              <text x="249" y="117" text-anchor="start">Vogelstang</text>
            </g>

            <!-- Innenstadt – highlighted center -->
            <g class="dp dp--main">
              <circle cx="112" cy="169" r="6"/>
              <text x="112" y="182" text-anchor="middle">Innenstadt</text>
            </g>

            <g class="dp">
              <circle cx="214" cy="171" r="4.5"/>
              <text x="223" y="175" text-anchor="start">Feudenheim</text>
            </g>

            <g class="dp">
              <circle cx="120" cy="206" r="4.5"/>
              <text x="111" y="210" text-anchor="end">Lindenhof</text>
            </g>

            <g class="dp">
              <circle cx="154" cy="217" r="4.5"/>
              <text x="154" y="230" text-anchor="middle">Almenhof</text>
            </g>

            <g class="dp">
              <circle cx="170" cy="235" r="4.5"/>
              <text x="170" y="248" text-anchor="middle">Neckarau</text>
            </g>

            <g class="dp">
              <circle cx="250" cy="301" r="4.5"/>
              <text x="250" y="314" text-anchor="middle">Rheinau</text>
            </g>

            <g class="dp">
              <circle cx="300" cy="206" r="4.5"/>
              <text x="309" y="210" text-anchor="start">Seckenheim</text>
            </g>

            <g class="dp">
              <circle cx="330" cy="227" r="4.5"/>
              <text x="322" y="240" text-anchor="middle">Friedrichsfeld</text>
            </g>
          </svg>

          <!-- Region footnote -->
          <div class="map-footer">
            <span class="map-footer-label">+ Region:</span>
            Ludwigshafen · Heidelberg · Viernheim · Weinheim · Speyer
          </div>

        </div>
      </div>

    </div>

  </div>
</section>

<style>
  .local-section {
    padding: 5rem 0 5.5rem;
    background: #fff;
  }

  /* Hook */
  .local-hook {
    max-width: 680px;
    margin-bottom: 3rem;
  }

  .local-hook h2 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--color-text-heading);
    margin: 0.375rem 0 0;
  }

  .local-hook h2 em {
    font-style: normal;
    color: var(--color-brand-accent);
  }

  /* Main grid */
  .local-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .local-grid {
      grid-template-columns: 1.1fr 1fr;
      gap: 4.5rem;
    }
  }

  /* Copy */
  .local-copy {
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  .local-lead {
    font-size: 1.0625rem;
    color: var(--color-text-body);
    line-height: 1.75;
    margin: 0;
  }

  .local-copy p {
    font-size: 0.9375rem;
    color: var(--color-text-body);
    line-height: 1.8;
    margin: 0;
  }

  .local-copy strong {
    color: var(--color-text-heading);
    font-weight: 600;
  }

  /* Service Bento */
  .service-bento-label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-top: 0.25rem;
  }

  .service-bento {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  @media (min-width: 540px) {
    .service-bento { grid-template-columns: repeat(3, 1fr); }
  }

  .service-bento-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
    padding: 0.875rem;
    background: var(--color-surface-warm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    text-decoration: none;
    transition: border-color 0.18s ease, background 0.18s ease, transform 0.18s ease;
  }

  .service-bento-card:hover {
    border-color: rgba(232,146,42,0.35);
    background: #fff;
    transform: translateY(-1px);
  }

  .bento-icon {
    opacity: 0.75;
    transition: opacity 0.18s ease;
  }

  .service-bento-card:hover .bento-icon {
    opacity: 1;
  }

  .bento-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-heading);
    line-height: 1.3;
  }

  .bento-sub {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    line-height: 1.3;
    text-align: center;
  }

  .local-cta {
    margin-top: 0.25rem;
    align-self: flex-start;
    font-size: 0.9rem;
  }

  /* Map Card */
  .local-map-wrap {
    position: sticky;
    top: 5.5rem;
  }

  @media (max-width: 767px) {
    .local-map-wrap { position: static; }
  }

  .map-card {
    background: var(--color-brand-primary);
    border-radius: var(--radius-card);
    padding: 1.5rem 1.5rem 1.25rem;
    overflow: hidden;
  }

  /* SVG map */
  .mannheim-svg {
    width: 100%;
    height: auto;
    display: block;
    overflow: visible;
  }

  .river {
    fill: none;
    stroke-linecap: round;
  }
  .river--rhein  { stroke: rgba(147,197,253,0.22); stroke-width: 7; }
  .river--neckar { stroke: rgba(147,197,253,0.16); stroke-width: 4.5; }

  .river-label {
    fill: rgba(147,197,253,0.3);
    font-size: 8px;
    font-family: var(--font-body, sans-serif);
  }

  /* District dots */
  .dp circle {
    fill: rgba(255,255,255,0.22);
    transition: fill 0.2s ease, r 0.15s ease;
    cursor: default;
  }
  .dp text {
    fill: rgba(255,255,255,0.5);
    font-size: 9px;
    font-family: var(--font-body, sans-serif);
    pointer-events: none;
    transition: fill 0.2s ease;
  }
  .dp:hover circle { fill: rgba(232,146,42,0.85); }
  .dp:hover text   { fill: rgba(255,255,255,0.9); }

  /* Innenstadt */
  .dp--main circle { fill: rgba(232,146,42,0.65); }
  .dp--main text   { fill: rgba(232,146,42,0.9); font-size: 10px; font-weight: 600; }
  .dp--main:hover circle { fill: rgba(232,146,42,1); }

  /* Region footnote */
  .map-footer {
    margin-top: 1rem;
    padding-top: 0.875rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    font-size: 0.75rem;
    color: rgba(255,255,255,0.35);
    line-height: 1.6;
  }

  .map-footer-label {
    font-weight: 600;
    color: rgba(255,255,255,0.45);
    margin-right: 0.25rem;
  }
</style>
