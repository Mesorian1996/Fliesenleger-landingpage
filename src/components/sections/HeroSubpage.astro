---
/**
 * HeroSubpage
 * @category sections
 * @description Compact hero for service and content pages with breadcrumb.
 */

import Icon from '@/components/ui/Icon.astro';

interface Props {
  headline: string;
  subline?: string;
  label?: string;
  image?: string;
  imageAlt?: string;
  breadcrumb?: Array<{ label: string; href?: string }>;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  headline,
  subline,
  label,
  image = '/assets/images/Fliesen_bad_12.jpeg',
  imageAlt = 'Limani Fliesenleger Mannheim',
  breadcrumb = [],
  ctaLabel = 'Jetzt anfragen',
  ctaHref = '#anfrage-funnel',
} = Astro.props;
---

<section class="subpage-hero" aria-label={headline}>
  <div class="subpage-hero__bg">
    <img
      src={image}
      alt={imageAlt}
      loading="eager"
      fetchpriority="high"
      decoding="sync"
      width="1600"
      height="700"
      class="subpage-hero__img"
    />
    <div class="subpage-hero__overlay"></div>
  </div>

  <div class="container subpage-hero__content">
    <!-- Breadcrumb -->
    {breadcrumb.length > 0 && (
      <nav class="subpage-hero__breadcrumb" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">Startseite</a></li>
          {breadcrumb.map((item, i) => (
            <li>
              <span class="sep" aria-hidden="true">/</span>
              {item.href && i < breadcrumb.length - 1
                ? <a href={item.href}>{item.label}</a>
                : <span aria-current="page">{item.label}</span>
              }
            </li>
          ))}
        </ol>
      </nav>
    )}

    {label && <span class="section-label section-label--light">{label}</span>}

    <h1 class="subpage-hero__h1" data-aos="fade-up">
      {headline}
    </h1>

    {subline && (
      <p class="subpage-hero__sub" data-aos="fade-up" data-aos-delay="80">
        {subline}
      </p>
    )}

    <div class="subpage-hero__cta" data-aos="fade-up" data-aos-delay="160">
      <a href={ctaHref} class="btn-primary">
        {ctaLabel}
      </a>
      <a href="tel:+491733293668" class="btn-outline-light" style="font-size:0.9rem;">
        <Icon name="phone" size={15} strokeWidth={2} />
        0173 329 3668
      </a>
    </div>
  </div>
</section>

<style>
  .subpage-hero {
    position: relative;
    min-height: 480px;
    display: flex;
    align-items: flex-end;
    padding-bottom: 4rem;
    padding-top: 6rem;
    overflow: hidden;
  }

  .subpage-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .subpage-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .subpage-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(12, 27, 46, 0.88) 0%,
      rgba(12, 27, 46, 0.70) 50%,
      rgba(12, 27, 46, 0.40) 100%
    );
  }

  .subpage-hero__content {
    position: relative;
    z-index: 1;
    max-width: 680px;
  }

  .subpage-hero__breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
  }

  .subpage-hero__breadcrumb li {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .subpage-hero__breadcrumb a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }
  .subpage-hero__breadcrumb a:hover { color: var(--color-brand-accent); }
  .subpage-hero__breadcrumb [aria-current="page"] { color: rgba(255,255,255,0.9); }

  .section-label--light {
    color: var(--color-brand-accent);
    background: rgba(232, 146, 42, 0.15);
    border-color: rgba(232, 146, 42, 0.3);
    margin-bottom: 0.875rem;
    display: inline-block;
  }

  .subpage-hero__h1 {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #fff;
    margin: 0 0 1rem;
  }

  .subpage-hero__sub {
    font-size: clamp(1rem, 1.5vw, 1.125rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    margin: 0 0 1.75rem;
    max-width: 560px;
  }

  .subpage-hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    align-items: center;
  }
</style>
