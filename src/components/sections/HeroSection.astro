---
/**
 * HeroSection
 * @category sections
 * @description Fullscreen hero slider — unified for mobile and desktop.
 *   Mobile: background image slider with dot navigation + touch swipe.
 *   Desktop: adds animated tab bar at bottom.
 */

import { SITE } from '@/config/site';
import Icon from '@/components/ui/Icon.astro';

const slides = [
  {
    bg: '/assets/images/Fliesen_schwimmbad_hero.webp',
    bgMobile: '/assets/images/Fliesen_schwimmbad_hero_mobile.webp',
    label: 'Fliesenarbeiten',
    title: 'Fliesen für Bad,\nKüche & Boden',
    text: 'Präzise verlegte Wand- und Bodenfliesen für Wohnräume, Bäder und Außenbereiche in Mannheim & Umgebung.',
  },
  {
    bg: '/assets/images/Malerarbeiten_bunt.jpeg',
    bgMobile: '/assets/images/Malerarbeiten_bunt.jpeg',
    label: 'Malerarbeiten',
    title: 'Saubere Maler-\nund Verputzarbeiten',
    text: 'Spachtel, Glattputz, Strukturputz und Anstrich – für Ihre Renovierung im Raum Mannheim.',
  },
  {
    bg: '/assets/images/Parkett_1.jpeg',
    bgMobile: '/assets/images/Parkett_1.jpeg',
    label: 'Bodenverlegung',
    title: 'Vinylboden, Parkett\nund Laminat',
    text: 'Bodenverlegung und Estricharbeiten für Miet- und Eigentumswohnungen in Mannheim & Ludwigshafen.',
  },
  {
    bg: '/assets/images/Verputzen2_hero.webp',
    bgMobile: '/assets/images/Verputzen2.jpg',
    label: 'Verputzarbeiten',
    title: 'Glatte Wände\nvon Q1 bis Q4',
    text: 'Glatt- oder Strukturputz – perfekt vorbereitet für Fliesen, Tapete oder Anstrich.',
  },
  {
    bg: '/assets/images/Wohnung_1_hero.webp',
    bgMobile: '/assets/images/Wohnung_6.jpeg',
    label: 'Wohnungssanierung',
    title: 'Ganze Wohnungen\nsanieren',
    text: 'Von Abbruch bis Fertigstellung – alle Gewerke aus einer Hand koordiniert in Mannheim.',
  },
];
---

<section id="heroSlider" class="hero" aria-label="Limani Fliesenleger – Leistungsübersicht">

  <!-- Background images -->
  {slides.map((slide, i) => (
    <div
      class:list={['hero-bg', i === 0 ? 'active' : '']}
      data-slide={i}
      aria-hidden="true"
    >
      <!-- Mobile image -->
      <img
        class="hero-bg-img hero-bg-img--mobile"
        src={slide.bgMobile}
        alt={slide.label}
        loading={i === 0 ? 'eager' : 'lazy'}
        fetchpriority={i === 0 ? 'high' : 'auto'}
        decoding="async"
      />
      <!-- Desktop image -->
      <img
        class="hero-bg-img hero-bg-img--desktop"
        src={slide.bg}
        alt={slide.label}
        loading={i === 0 ? 'eager' : 'lazy'}
        fetchpriority={i === 0 ? 'high' : 'auto'}
        decoding="async"
      />
    </div>
  ))}

  <div class="hero-overlay" aria-hidden="true"></div>

  <!-- Content -->
  <div class="container hero-container">

    <!-- Text blocks -->
    <div class="hero-content">
      {slides.map((slide, i) => (
        <div class:list={['hero-text', i === 0 ? 'active' : '']} data-slide={i}>
          <span class="hero-kicker">{slide.label}</span>
          {i === 0 ? (
            <h1 class="hero-title">
              {slide.title.split('\n').map((line, j) => (
                <>
                  {line}
                  {j === 0 && <br />}
                </>
              ))}
            </h1>
          ) : (
            <p class="hero-title" aria-hidden="true">
              {slide.title.split('\n').map((line, j) => (
                <>
                  {line}
                  {j === 0 && <br />}
                </>
              ))}
            </p>
          )}
          <p class="hero-sub">{slide.text}</p>
          <div class="hero-actions">
            <a href="#anfrage-funnel" class="btn-primary hero-btn-primary">
              Kostenloses Angebot
              <Icon name="chevronRight" size={16} strokeWidth={2.5} />
            </a>
            <a href={`tel:${SITE.phoneTel}`} class="btn-outline-light hero-btn-outline">
              <Icon name="phone" size={15} strokeWidth={2} />
              {SITE.phone}
            </a>
          </div>
        </div>
      ))}
    </div>

  </div>

  <!-- Mobile: dot navigation (outside container → positions relative to .hero) -->
  <div class="hero-dots" aria-label="Slide Navigation">
    {slides.map((_, i) => (
      <button
        class:list={['hero-dot', i === 0 ? 'active' : '']}
        data-slide={i}
        type="button"
        aria-label={`Slide ${i + 1}`}
      />
    ))}
  </div>

  <!-- Desktop: tab bar (outside container → positions relative to .hero) -->
  <div class="hero-tabs" role="tablist" aria-label="Leistungsauswahl">
    {slides.map((slide, i) => (
      <button
        class:list={['hero-tab', i === 0 ? 'active' : '']}
        data-slide={i}
        role="tab"
        aria-selected={i === 0}
        type="button"
      >
        <span class="hero-tab-progress" aria-hidden="true"></span>
        {slide.label}
      </button>
    ))}
  </div>

  <!-- Prev / Next arrows (both mobile + desktop, hidden on small) -->
  <button id="heroPrev" class="hero-nav-btn hero-nav-prev" type="button" aria-label="Vorheriger Slide">
    <Icon name="chevronLeft" size={20} strokeWidth={2.5} />
  </button>
  <button id="heroNext" class="hero-nav-btn hero-nav-next" type="button" aria-label="Nächster Slide">
    <Icon name="chevronRight" size={20} strokeWidth={2.5} />
  </button>

</section>

<style>
  /* ── Base ─────────────────────────────────────────────────── */
  .hero {
    position: relative;
    height: 100dvh;
    display: flex;
    align-items: flex-start;
    overflow: hidden;
    color: #fff;
  }

  /* ── Backgrounds ──────────────────────────────────────────── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0;
    transition: opacity 0.7s ease;
  }
  .hero-bg.active { opacity: 1; }

  .hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-bg-img--mobile  { display: block; }
  .hero-bg-img--desktop { display: none; }

  @media (min-width: 768px) {
    .hero-bg-img--mobile  { display: none; }
    .hero-bg-img--desktop { display: block; }
  }

  /* ── Overlay ──────────────────────────────────────────────── */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(12,27,46,0.22) 0%,
      rgba(12,27,46,0.70) 100%
    );
  }

  /* ── Container / layout ───────────────────────────────────── */
  .hero-container {
    position: relative;
    z-index: 3;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-top: 32vh;
  }

  @media (min-width: 768px) {
    .hero-container {
      padding-top: 50vh;
    }
  }

  /* ── Text blocks ──────────────────────────────────────────── */
  .hero-content {
    position: relative;
    max-width: 620px;
    padding-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .hero-content { padding-bottom: 1rem; }
  }

  .hero-text {
    display: none;
    flex-direction: column;
    align-items: flex-start;
    animation: heroTextIn 0.45s ease both;
  }
  .hero-text.active { display: flex; }

  @keyframes heroTextIn {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .hero-kicker {
    display: block;
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand-accent);
    margin-bottom: 0.75rem;
  }

  .hero-title {
    font-size: clamp(1.875rem, 6vw, 3.75rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.08;
    margin: 0 0 1.125rem;
    letter-spacing: -0.02em;
  }

  .hero-sub {
    font-size: clamp(0.9375rem, 1.5vw, 1.0625rem);
    color: rgba(255,255,255,0.88);
    line-height: 1.65;
    margin: 0 0 1.875rem;
    max-width: 500px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .hero-btn-primary { font-size: 1rem; padding: 0.875rem 2rem; }
  .hero-btn-outline  { font-size: 1rem; padding: 0.875rem 1.75rem; display: inline-flex; align-items: center; gap: 0.5rem; }

  @media (max-width: 767px) {
    .hero-btn-outline { display: none; }
  }

  /* ── Mobile dot navigation ────────────────────────────────── */
  .hero-dots {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    position: absolute;
    bottom: 1.75rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
  }

  @media (min-width: 768px) {
    .hero-dots { display: none; }
  }

  .hero-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.25s ease, transform 0.25s ease, width 0.25s ease;
  }

  .hero-dot.active {
    background: var(--color-brand-accent);
    width: 22px;
    border-radius: 4px;
    transform: none;
  }

  /* ── Desktop tab bar ──────────────────────────────────────── */
  .hero-tabs {
    display: none;
  }

  @media (min-width: 768px) {
    .hero-tabs {
      display: flex;
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 100vw;
      z-index: 4;
      background: rgba(12,27,46,0.65);
      backdrop-filter: blur(8px);
      border-top: 1px solid rgba(255,255,255,0.12);
      overflow-x: auto;
      scrollbar-width: none;
      padding: 0;
    }
    .hero-tabs::-webkit-scrollbar { display: none; }
  }

  .hero-tab {
    position: relative;
    flex: 1;
    min-width: min-content;
    padding: 1.1rem 1rem 1rem;
    background: none;
    border: none;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(255,255,255,0.6);
    cursor: pointer;
    transition: color 0.2s ease;
    white-space: nowrap;
    text-align: center;
  }
  .hero-tab:hover { color: rgba(255,255,255,0.9); }
  .hero-tab.active { color: #fff; font-weight: 600; }
  .hero-tab.active::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
    background: var(--color-brand-accent);
    border-radius: 3px 3px 0 0;
  }

  .hero-tab-progress {
    position: absolute;
    bottom: 0; left: 0;
    height: 3px;
    background: var(--color-brand-accent);
    border-radius: 3px 3px 0 0;
    width: 0;
    opacity: 0;
  }
  .hero-tab.running .hero-tab-progress {
    opacity: 1;
    animation: tabProgress 5s linear forwards;
  }
  @keyframes tabProgress {
    from { width: 0; }
    to   { width: 100%; }
  }

  /* ── Prev / Next arrows ───────────────────────────────────── */
  .hero-nav-btn {
    display: none; /* hidden on mobile */
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 42px;
    height: 42px;
    border-radius: 0.625rem;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease;
    backdrop-filter: blur(4px);
  }
  .hero-nav-btn:hover { background: rgba(255,255,255,0.22); }

  .hero-nav-prev { left: 1rem; }
  .hero-nav-next { right: 1rem; }

  /* Show arrows on desktop, shift above tab bar */
  @media (min-width: 768px) {
    .hero-nav-btn {
      display: flex;
      top: calc(50% - 1.6rem);
    }
    .hero-nav-prev { left: 1.25rem; }
    .hero-nav-next { right: 1.25rem; }
  }
</style>

<script>
  function initHero() {
    const slider = document.getElementById('heroSlider');
    if (!slider) return;

    const bgs        = slider.querySelectorAll<HTMLElement>('.hero-bg');
    const texts      = slider.querySelectorAll<HTMLElement>('.hero-text');
    const tabs       = slider.querySelectorAll<HTMLElement>('.hero-tab');
    const dots       = slider.querySelectorAll<HTMLButtonElement>('.hero-dot');
    const prevBtn    = document.getElementById('heroPrev');
    const nextBtn    = document.getElementById('heroNext');

    let current = 0;
    let autoTimer: ReturnType<typeof setInterval> | null = null;

    function goTo(index: number) {
      const total = bgs.length;
      const next  = ((index % total) + total) % total;

      bgs.forEach((el, i)   => el.classList.toggle('active', i === next));
      texts.forEach((el, i) => el.classList.toggle('active', i === next));

      tabs.forEach((tab, i) => {
        tab.classList.toggle('active', i === next);
        tab.classList.remove('running');
        tab.setAttribute('aria-selected', String(i === next));
        void tab.offsetWidth; // reflow for animation restart
        if (i === next) tab.classList.add('running');
      });

      dots.forEach((dot, i) => dot.classList.toggle('active', i === next));

      current = next;
    }

    function startAuto() {
      stopAuto();
      autoTimer = setInterval(() => goTo(current + 1), 5500);
    }

    function stopAuto() {
      if (autoTimer) clearInterval(autoTimer);
    }

    // Tab clicks (desktop)
    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => { goTo(i); stopAuto(); startAuto(); });
    });

    // Dot clicks (mobile)
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => { goTo(i); stopAuto(); startAuto(); });
    });

    // Arrow buttons
    prevBtn?.addEventListener('click', () => { goTo(current - 1); stopAuto(); startAuto(); });
    nextBtn?.addEventListener('click', () => { goTo(current + 1); stopAuto(); startAuto(); });

    // Touch swipe (mobile)
    let touchStartX = 0;
    let touchStartY = 0;

    slider.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    }, { passive: true });

    slider.addEventListener('touchend', (e: TouchEvent) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
        if (dx < 0) { goTo(current + 1); } else { goTo(current - 1); }
        stopAuto();
        startAuto();
      }
    }, { passive: true });

    goTo(0);
    startAuto();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHero);
  } else {
    initHero();
  }
</script>
