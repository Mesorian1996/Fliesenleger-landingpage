---
/**
 * Icon
 * @category ui
 * @description Renders a Phosphor icon via CSS class (ph ph-*).
 * Weight is inferred from strokeWidth + fill props.
 *
 * Usage:
 *   <Icon name="phone" />
 *   <Icon name="star" size={20} fill="#e8922a" strokeWidth={0} />
 *   <Icon name="facebook" fill="currentColor" strokeWidth={0} />
 */

import { PhosphorNames, type IconName } from './Icons';

interface Props {
  name: IconName;
  size?: number;
  strokeWidth?: number;
  fill?: string;
  stroke?: string;
  class?: string;
  style?: string;
}

const {
  name,
  size = 20,
  strokeWidth = 2,
  fill = 'none',
  stroke = 'currentColor',
  class: className,
  style,
} = Astro.props;

const iconClass = PhosphorNames[name];

// Map to Phosphor weight class
const isFilled = fill !== 'none' && strokeWidth === 0;
const weightClass = isFilled ? 'ph-fill'
  : strokeWidth >= 2.5   ? 'ph-bold'
  : '';

const color = isFilled ? fill : stroke;
---

<i
  class:list={[weightClass || 'ph', `ph-${iconClass}`, className]}
  style={`font-size:${size}px;color:${color};line-height:1;${style ?? ''}`}
  aria-hidden="true"
/>
