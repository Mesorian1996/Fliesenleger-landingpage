---
import '../styles/globals.css';
import '@fontsource-variable/outfit';
import '@fontsource-variable/dm-sans';
import { SITE } from '@/config/site';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  robots?: string;
  schema?: object | object[];
}

const {
  title,
  description = SITE.description,
  canonical = Astro.url.href,
  ogImage = `${SITE.url}/assets/images/hero-limani-fliesenleger.webp`,
  robots = 'index,follow',
  schema,
} = Astro.props;

const fullTitle = title.includes('Limani') ? title : `${title} | Limani Fliesenleger`;
const canonicalUrl = canonical.endsWith('/') ? canonical : `${canonical}/`;

const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content={robots} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:site_name" content={SITE.name} />

  <!-- Favicons -->
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicon/favicon-180x180.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon/favicon-16x16.png" />
  <link rel="shortcut icon" href="/assets/favicon/favicon.ico" type="image/x-icon" />

  <!-- Phosphor Icons -->
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/regular/style.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/bold/style.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.1/src/fill/style.css" />

  <!-- Preload hero images -->
  <slot name="preload" />

  <!-- Structured Data -->
  {schemas.map(s => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <!-- LocalBusiness Schema — sitewide -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Limani Fliesenleger & Malerbetrieb",
    "image": `${SITE.url}/assets/images/Limani_Logo_modern.webp`,
    "description": "Fliesen-, Maler-, Verputz- und Sanierungsarbeiten in Mannheim und Umgebung. Präzises Handwerk mit über 30 Jahren Erfahrung.",
    "url": SITE.url,
    "telephone": "+49 173 3293668",
    "email": SITE.email,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "E7 13",
      "addressLocality": "Mannheim",
      "postalCode": "68159",
      "addressCountry": "DE"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 49.488888,
      "longitude": 8.469167
    },
    "areaServed": ["Mannheim", "Ludwigshafen", "Heidelberg", "Rhein-Neckar-Region"],
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "08:00",
        "closes": "18:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": "Saturday",
        "opens": "09:00",
        "closes": "13:00"
      }
    ],
    "priceRange": "€€",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "reviewCount": "7",
      "bestRating": "5"
    },
    "review": [
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Donato de Tullio" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Sehr zufrieden mit der Arbeit von Limani Fliesenleger! Die Kommunikation war von Anfang an professionell und zuverlässig. Die Arbeiten wurden sauber, präzise und termingerecht ausgeführt. Man merkt sofort die hohe Qualität und die Liebe zum Detail.",
        "datePublished": "2026-02-01"
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Julius Steinhäuser" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Absolut empfehlenswert! Herr Limani ist ein äußerst zuverlässiger, professioneller und freundlicher Handwerker. Die Arbeit wurde schnell, sauber und mit großer Sorgfalt ausgeführt – das Ergebnis hat meine Erwartungen sogar übertroffen.",
        "datePublished": "2026-02-01"
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Nezir Neziri" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Ich bin äußerst zufrieden mit der Arbeit von Herrn Limani. Von der ersten Beratung bis zur finalen Umsetzung hat er durch seine Professionalität, Zuverlässigkeit und handwerkliche Präzision überzeugt.",
        "datePublished": "2025-12-01"
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Ivano T." },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Ich kann Limani Fliesenleger wärmstens empfehlen! Das Team ist unglaublich professionell, zuverlässig und kreativ. Die Arbeit ist von höchster Qualität, und das Ergebnis hat meine Erwartungen übertroffen.",
        "datePublished": "2026-02-01"
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Aleko Offiziell" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Wir haben eine jahrelange Erfahrung mit Firma Limani. Wir wurden nie enttäuscht. Immer wieder hat die Firma perfekte Arbeiten geliefert. Der Chef an sich ist einer der sympathischsten Menschen die ich je kennengelernt habe.",
        "datePublished": "2026-02-01"
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "Elias" },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Echt super Arbeit! Man merkt sofort, dass hier Profis am Werk sind und keine 0815 Fliesenleger. Die Leute sind super nett, pünktlich und wissen genau, was sie tun. Kann ich definitiv nur weiterempfehlen!",
        "datePublished": "2026-02-01"
      },
      {
        "@type": "Review",
        "author": { "@type": "Person", "name": "L." },
        "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
        "reviewBody": "Schnell, sauber und sehr erfahren. Immer wieder gerne! Da legt man sein Vertrauen gerne in die Hände erfahrener Handwerker, bei solchen hervorragenden Ergebnissen!",
        "datePublished": "2025-12-01"
      }
    ],
    "sameAs": [
      "https://www.instagram.com/limani_fliesenleger/",
      "https://www.facebook.com/limanifliesenleger/"
    ]
  })} />

</head>
<body>
  <slot />

  <!-- FAB Speed Dial -->
  <div class="fab-wrap" id="fabWrap">
    <div class="fab-actions" id="fabActions" aria-hidden="true">
      <!-- Anrufen (top, i=2 → last to animate in) -->
      <div class="fab-item" style="--fab-i:2;">
        <span class="fab-label">Anrufen</span>
        <a href={`tel:${SITE.phoneTel}`} class="fab-action-btn" aria-label="Anrufen">
          <Icon name="phone" size={20} strokeWidth={2} />
        </a>
      </div>
      <!-- Anfrage stellen (middle, i=1) -->
      <div class="fab-item" style="--fab-i:1;">
        <span class="fab-label">Anfrage stellen</span>
        <a href="#anfrage-funnel" class="fab-action-btn" id="fabFunnelLink" aria-label="Anfrage stellen">
          <Icon name="message" size={20} strokeWidth={2} />
        </a>
      </div>
      <!-- Nach oben (closest to FAB, i=0 → first to animate in) -->
      <div class="fab-item" style="--fab-i:0;">
        <span class="fab-label">Nach oben</span>
        <button type="button" class="fab-action-btn" id="fabScrollTop" aria-label="Nach oben scrollen">
          <Icon name="chevronUp" size={20} strokeWidth={2.5} />
        </button>
      </div>
    </div>
    <!-- Main FAB trigger -->
    <button type="button" class="fab-main-btn" id="fabMain" aria-label="Aktionen" aria-expanded="false">
      <Icon name="plus" size={22} strokeWidth={2.5} class="fab-icon-plus" />
      <Icon name="close" size={22} strokeWidth={2.5} class="fab-icon-close" />
    </button>
  </div>

  <!-- AOS: Animate on Scroll via IntersectionObserver -->
  <script>
    function initAos() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(el => {
          if (el.isIntersecting) {
            el.target.classList.add('aos-animate');
            observer.unobserve(el.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('[data-aos]').forEach(el => observer.observe(el));
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAos);
    } else {
      initAos();
    }
  </script>

  <script>
    function initFab() {
      const fabWrap = document.getElementById('fabWrap');
      const fabMain = document.getElementById('fabMain');
      const fabActions = document.getElementById('fabActions');
      const fabScrollTop = document.getElementById('fabScrollTop');
      const fabFunnelLink = document.getElementById('fabFunnelLink');

      if (!fabWrap || !fabMain || !fabActions) return;

      let isOpen = false;
      let funnelVisible = false;

      // Hide FAB while funnel is in view — prevents z-index overlap with Weiter button
      const funnelEl = document.getElementById('anfrage-funnel');
      if (funnelEl) {
        new IntersectionObserver((entries) => {
          funnelVisible = entries[0].isIntersecting;
          if (funnelVisible) {
            fabWrap.classList.remove('show');
            if (isOpen) close();
          }
        }, { threshold: 0.1 }).observe(funnelEl);
      }

      window.addEventListener('scroll', () => {
        if (funnelVisible) return;
        if (window.scrollY > 400) {
          fabWrap.classList.add('show');
        } else {
          fabWrap.classList.remove('show');
          if (isOpen) close();
        }
      }, { passive: true });

      function open() {
        isOpen = true;
        fabMain.classList.add('open');
        fabActions.classList.add('open');
        fabMain.setAttribute('aria-expanded', 'true');
        fabActions.setAttribute('aria-hidden', 'false');
      }

      function close() {
        isOpen = false;
        fabMain.classList.remove('open');
        fabActions.classList.remove('open');
        fabMain.setAttribute('aria-expanded', 'false');
        fabActions.setAttribute('aria-hidden', 'true');
      }

      fabMain.addEventListener('click', (e) => {
        e.stopPropagation();
        isOpen ? close() : open();
      });

      fabScrollTop?.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
        close();
      });

      fabFunnelLink?.addEventListener('click', () => close());

      document.addEventListener('click', (e) => {
        if (isOpen && !fabWrap.contains(e.target as Node)) close();
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFab);
    } else {
      initFab();
    }
  </script>
</body>
</html>
