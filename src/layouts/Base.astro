---
import '../styles/globals.css';
import { SITE } from '@/config/site';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  robots?: string;
  schema?: object | object[];
}

const {
  title,
  description = SITE.description,
  canonical = Astro.url.href,
  ogImage = `${SITE.url}/assets/images/hero-limani-fliesenleger.webp`,
  robots = 'index,follow',
  schema,
} = Astro.props;

const fullTitle = title.includes('Limani') ? title : `${title} | Limani Fliesenleger`;
const canonicalUrl = canonical.endsWith('/') && canonical !== `${SITE.url}/`
  ? canonical.slice(0, -1)
  : canonical;

const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content={robots} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:site_name" content={SITE.name} />

  <!-- Favicons -->
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicon/favicon-180x180.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon/favicon-16x16.png" />
  <link rel="shortcut icon" href="/assets/favicon/favicon.ico" type="image/x-icon" />

  <!-- Preload fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=DM+Sans:wght@400;500;600;700&display=swap"
  />

  <!-- Preload hero images -->
  <slot name="preload" />

  <!-- Structured Data -->
  {schemas.map(s => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}

  <!-- LocalBusiness Schema — sitewide -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Limani Fliesenleger & Malerbetrieb",
    "image": `${SITE.url}/assets/images/Limani_Logo_modern.webp`,
    "description": "Fliesen-, Maler-, Verputz- und Sanierungsarbeiten in Mannheim und Umgebung. Präzises Handwerk mit über 30 Jahren Erfahrung.",
    "url": SITE.url,
    "telephone": "+49 173 3293668",
    "email": SITE.email,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "E7 13",
      "addressLocality": "Mannheim",
      "postalCode": "68159",
      "addressCountry": "DE"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 49.488888,
      "longitude": 8.469167
    },
    "areaServed": ["Mannheim", "Ludwigshafen", "Heidelberg", "Rhein-Neckar-Region"],
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "08:00",
        "closes": "18:00"
      },
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": "Saturday",
        "opens": "09:00",
        "closes": "13:00"
      }
    ],
    "priceRange": "€€",
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "5",
      "reviewCount": "4"
    },
    "sameAs": [
      "https://www.instagram.com/limani_fliesenleger/",
      "https://www.facebook.com/limanifliesenleger/"
    ]
  })} />

  <!-- GA4 -->
  <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.ga4}`}></script>
  <script is:inline define:vars={{ gaId: SITE.ga4 }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', gaId);
  </script>
</head>
<body>
  <slot />

  <!-- Fixed: Quick Call -->
  <a href={`tel:${SITE.phoneTel}`} class="quick-call-btn" aria-label="Jetzt anrufen" title="Telefonisch anfragen">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.7H6.6a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.3a16 16 0 0 0 6 6l.86-1.22a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.4 17.4z"/>
    </svg>
  </a>

  <!-- Fixed: Back to top -->
  <button id="goTopBtn" class="go-top-btn" aria-label="Nach oben scrollen" type="button">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="18,15 12,9 6,15"/>
    </svg>
  </button>

  <!-- AOS: Animate on Scroll via IntersectionObserver -->
  <script>
    function initAos() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(el => {
          if (el.isIntersecting) {
            el.target.classList.add('aos-animate');
            observer.unobserve(el.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('[data-aos]').forEach(el => observer.observe(el));
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAos);
    } else {
      initAos();
    }
  </script>

  <script>
    function initScrollBehaviors() {
      const goTopBtn = document.getElementById('goTopBtn');
      if (!goTopBtn) return;

      const onScroll = () => {
        if (window.scrollY > 400) {
          goTopBtn.classList.add('show');
        } else {
          goTopBtn.classList.remove('show');
        }
      };

      window.addEventListener('scroll', onScroll, { passive: true });
      goTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initScrollBehaviors);
    } else {
      initScrollBehaviors();
    }
  </script>
</body>
</html>
